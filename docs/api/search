dsight"],"tags":[],"url":"/calendar"},"2":{"id":"/calendar-0","page_id":"/calendar","tags":[],"type":"text","url":"/calendar","content":"Let Hindsight watch your calendar and start your meetings for you — notify or auto-record, with everything staying on your Mac."},"3":{"id":"/calendar-1","page_id":"/calendar","type":"heading","tags":[],"url":"/calendar#connect-a-calendar","content":"Connect a calendar"},"4":{"id":"/calendar-2","page_id":"/calendar","type":"heading","tags":[],"url":"/calendar#choose-a-behavior","content":"Choose a behavior"},"5":{"id":"/calendar-3","page_id":"/calendar","type":"heading","tags":[],"url":"/calendar#lead-time","content":"Lead time"},"6":{"id":"/calendar-4","page_id":"/calendar","type":"heading","tags":[],"url":"/calendar#which-events-count","content":"Which events count"},"7":{"id":"/calendar-5","page_id":"/calendar","type":"heading","tags":[],"url":"/calendar#the-countdown","content":"The countdown"},"8":{"id":"/calendar-6","page_id":"/calendar","type":"heading","tags":[],"url":"/calendar#changes-apply-right-away","content":"Changes apply right away"},"9":{"id":"/calendar-7","page_id":"/calendar","type":"heading","tags":[],"url":"/calendar#everything-stays-on-your-mac","content":"Everything stays on your Mac"},"10":{"id":"/calendar-8","page_id":"/calendar","tags":[],"type":"text","url":"/calendar","content":"Hindsight can watch your calendar so you never miss the start of a meeting. When\nan upcoming event matches your rules, Hindsight either drops a quiet reminder or\nopens a short, cancellable countdown and begins the minutes for you."},"11":{"id":"/calendar-9","page_id":"/calendar","tags":[],"type":"text","url":"/calendar","content":"This is strictly opt-in. Until you connect a calendar and pick a behavior,\nHindsight ignores your calendar entirely."},"12":{"id":"/calendar-10","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#connect-a-calendar","content":"Open **Settings → The Minutes → The Calendar**."},"13":{"id":"/calendar-11","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#connect-a-calendar","content":"Select **Grant Calendar Access**. macOS will ask for permission once."},"14":{"id":"/calendar-12","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#connect-a-calendar","content":"Choose a **Calendar behavior** (see the modes below)."},"15":{"id":"/calendar-13","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#connect-a-calendar","content":"Calendar access is read-only and local: events stay on your Mac, and Hindsight\nnever uploads them. They're read fresh each time and never stored."},"16":{"id":"/calendar-14","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#connect-a-calendar","content":"macOS only asks for calendar permission once. If you decline, you can re-enable\nit later in **System Settings → Privacy & Security → Calendars**."},"17":{"id":"/calendar-15","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#choose-a-behavior","content":"Set **Calendar behavior** to one of three modes:"},"18":{"id":"/calendar-16","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#choose-a-behavior","content":"**Off** — Hindsight ignores your calendar. This is the default."},"19":{"id":"/calendar-17","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#choose-a-behavior","content":"**Notify before meetings** — a quiet note slips in before each meeting begins.\nNothing records on its own."},"20":{"id":"/calendar-18","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#choose-a-behavior","content":"**Start recording automatically** — Hindsight shows a 5-second cancellable\ncountdown, then begins the minutes."},"21":{"id":"/calendar-19","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#choose-a-behavior","content":"When you pick a non-Off mode, Hindsight will ask for notification permission so\nreminders can appear. If notifications are turned off in System Settings,\nHindsight shows a warning with a shortcut to fix it."},"22":{"id":"/calendar-20","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#lead-time","content":"Under **Remind me**, choose how far ahead you're nudged:"},"23":{"id":"/calendar-21","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#lead-time","content":"**At start time**"},"24":{"id":"/calendar-22","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#lead-time","content":"**1 minute before**"},"25":{"id":"/calendar-23","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#lead-time","content":"**5 minutes before** (default)"},"26":{"id":"/calendar-24","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#lead-time","content":"**10 minutes before**"},"27":{"id":"/calendar-25","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#lead-time","content":"Each reminder fires once per meeting. If your Mac is asleep or busy at the exact\nmoment, Hindsight still catches the reminder for a short window afterward so a\nlate tick won't make you miss it."},"28":{"id":"/calendar-26","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#which-events-count","content":"Not every calendar entry deserves a reminder. Under **Which events count**,\npick the filter that fits how you work:"},"29":{"id":"/calendar-27","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#which-events-count","content":"**With video link** (default) — only events that carry a recognized\nconference link. Hindsight detects Zoom, Google Meet, Microsoft Teams, Webex,\nAround, and Whereby, plus other common meeting URLs."},"30":{"id":"/calendar-28","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#which-events-count","content":"**With participants** — any event that has at least one other attendee."},"31":{"id":"/calendar-29","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#which-events-count","content":"**All events** — every timed event on your calendar."},"32":{"id":"/calendar-30","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#which-events-count","content":"Higher-precision filters skip personal blocks and solo focus time. All-day\nevents and meetings you've declined are always skipped, whatever filter you\nchoose."},"33":{"id":"/calendar-31","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#which-events-count","content":"If you have several calendars, expand **Calendars** to exclude specific ones —\na personal calendar, say, while keeping your work calendar. New calendars are\nincluded by default."},"34":{"id":"/calendar-32","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#the-countdown","content":"In **Start recording automatically** mode, when a matching meeting begins\nHindsight opens a small countdown in the top-right corner. It shows the meeting\ntitle, the service name, and the attendee count, and counts down for 5 seconds."},"35":{"id":"/calendar-33","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#the-countdown","content":"Do nothing and recording starts automatically when the countdown ends."},"36":{"id":"/calendar-34","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#the-countdown","content":"Press Return to start immediately."},"37":{"id":"/calendar-35","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#the-countdown","content":"Press Esc, click the toast, or hit the ✕ to cancel. That meeting\nwon't try again."},"38":{"id":"/calendar-36","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#the-countdown","content":"The countdown only appears when you're not already recording, and only for\nmeetings you've accepted or tentatively accepted (and your own untracked\nblocks). Meetings you haven't responded to won't auto-record, since recording an\nunaccepted meeting would be a surprise — but you can still get a reminder for\nthem."},"39":{"id":"/calendar-37","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#the-countdown","content":"Calendar data never stops a recording. If a meeting runs long, Hindsight keeps\nrecording until you stop it yourself."},"40":{"id":"/calendar-38","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#changes-apply-right-away","content":"Any change you make takes effect immediately. Switch back to **Off** and\nHindsight stops watching your calendar entirely — a disabled feature does no\nwork in the background. Adjust your lead time, filter, or excluded calendars and\nthe next reminder or countdown follows the new rules. If a countdown is on\nscreen when you change a setting, it closes."},"41":{"id":"/calendar-39","page_id":"/calendar","tags":[],"type":"text","url":"/calendar#everything-stays-on-your-mac","content":"Calendar auto-start reads your events locally and acts on them locally. Nothing\nabout your calendar — titles, attendees, links, or times — ever leaves your Mac."},"42":{"id":"/cli","page_id":"/cli","type":"page","content":"Command line","breadcrumbs":["Hindsight"],"tags":[],"url":"/cli"},"43":{"id":"/cli-0","page_id":"/cli","tags":[],"type":"text","url":"/cli","content":"hindsight-cli is a companion tool that shares the app's database — list and export meetings, transcribe files on-device, manage speech models, inspect your Second Brain, and run LLM tasks from the terminal."},"44":{"id":"/cli-1","page_id":"/cli","type":"heading","tags":[],"url":"/cli#meetings","content":"Meetings"},"45":{"id":"/cli-2","page_id":"/cli","type":"heading","tags":[],"url":"/cli#transcribe","content":"Transcribe"},"46":{"id":"/cli-3","page_id":"/cli","type":"heading","tags":[],"url":"/cli#models","content":"Models"},"47":{"id":"/cli-4","page_id":"/cli","type":"heading","tags":[],"url":"/cli#second-brain","content":"Second Brain"},"48":{"id":"/cli-5","page_id":"/cli","type":"heading","tags":[],"url":"/cli#llm","content":"LLM"},"49":{"id":"/cli-6","page_id":"/cli","type":"heading","tags":[],"url":"/cli#import","content":"Import"},"50":{"id":"/cli-7","page_id":"/cli","type":"heading","tags":[],"url":"/cli#json-output","content":"JSON output"},"51":{"id":"/cli-8","page_id":"/cli","type":"heading","tags":[],"url":"/cli#exit-codes","content":"Exit codes"},"52":{"id":"/cli-9","page_id":"/cli","tags":[],"type":"text","url":"/cli","content":"Hindsight ships with a companion command-line tool, `hindsight-cli`, that talks\nto the same database as the app. Anything you record, transcribe, or learn in\nthe app is visible from the terminal, and anything the CLI writes shows up in\nthe app. It is handy for scripting, exporting, and feeding your transcripts into\nother tools."},"53":{"id":"/cli-10","page_id":"/cli","tags":[],"type":"text","url":"/cli","content":"Every command accepts `--json` for clean, machine-readable output. Progress and\nstatus messages go to standard error, so the JSON on standard output stays\npipeable."},"54":{"id":"/cli-11","page_id":"/cli","tags":[],"type":"text","url":"/cli","content":"By default the CLI uses the app's shared database. Pass `--database <path>` on\nmost commands to point at a different one."},"55":{"id":"/cli-12","page_id":"/cli","tags":[],"type":"text","url":"/cli#meetings","content":"Work with your saved meeting recordings and their transcripts."},"56":{"id":"/cli-13","page_id":"/cli","tags":[],"type":"text","url":"/cli#meetings","content":"You can refer to a meeting by its full ID, a unique ID prefix (at least four\nhex characters), or a unique title."},"57":{"id":"/cli-14","page_id":"/cli","tags":[],"type":"text","url":"/cli#meetings","content":"**Export** supports several formats with `--format`: `txt` (default),\n`markdown`, `srt`, `vtt`, and `json`. By default the file is written as\n`<title>.<ext>` in the current directory; use `--output <path>` to choose the\nname, or `--stdout` to print instead of writing a file."},"58":{"id":"/cli-15","page_id":"/cli","tags":[],"type":"text","url":"/cli#meetings","content":"Each meeting also keeps **notes** and saved **results** (the output of prompts\nyou ran on it):"},"59":{"id":"/cli-16","page_id":"/cli","tags":[],"type":"text","url":"/cli#meetings","content":"Use `-` in place of text to read from standard input."},"60":{"id":"/cli-17","page_id":"/cli","tags":[],"type":"text","url":"/cli#transcribe","content":"Transcribe any audio or video file with the on-device speech engines. The file\nis decoded to audio and recognized locally — nothing leaves your Mac."},"61":{"id":"/cli-18","page_id":"/cli","tags":[],"type":"text","url":"/cli#transcribe","content":"Key options:"},"62":{"id":"/cli-19","page_id":"/cli","tags":[],"type":"text","url":"/cli#transcribe","content":"`--engine` — `parakeet` (default), `whisper`, or `app-default` (use whatever\nengine the app is set to)."},"63":{"id":"/cli-20","page_id":"/cli","tags":[],"type":"text","url":"/cli#transcribe","content":"`--language` — language hint for Whisper, e.g. `en`, `it`."},"64":{"id":"/cli-21","page_id":"/cli","tags":[],"type":"text","url":"/cli#transcribe","content":"`--format` — `text` (default), `transcript` (timestamped lines), or `json`."},"65":{"id":"/cli-22","page_id":"/cli","tags":[],"type":"text","url":"/cli#transcribe","content":"`--processing` — `raw`, `clean`, or `app-default` (default; follows your\nVocabulary setting). `clean` rebuilds punctuation and applies your custom\nwords."},"66":{"id":"/cli-23","page_id":"/cli","tags":[],"type":"text","url":"/cli#transcribe","content":"`--diarize` — separate speakers and label each turn (Speaker 1, Speaker 2, …).\nTune with `--diar-threshold` (default `0.6`; lower finds more speakers) and\n`--diar-max-speakers` (default `6`)."},"67":{"id":"/cli-24","page_id":"/cli","tags":[],"type":"text","url":"/cli#transcribe","content":"`--no-save` — transcribe without adding the result to your library."},"68":{"id":"/cli-25","page_id":"/cli","tags":[],"type":"text","url":"/cli#transcribe","content":"By default the result is saved to your library so it appears in the app."},"69":{"id":"/cli-26","page_id":"/cli","tags":[],"type":"text","url":"/cli#models","content":"Manage the on-device speech models."},"70":{"id":"/cli-27","page_id":"/cli","tags":[],"type":"text","url":"/cli#models","content":"The Parakeet engine (`parakeet-tdt-0.6b-v3`) downloads automatically the first\ntime it is used, so `download` is only needed for `whisper`. Use `warm-up` to\nprepare an engine ahead of time (it may download on first run), and `clear` to\nremove cached models from disk."},"71":{"id":"/cli-28","page_id":"/cli","tags":[],"type":"text","url":"/cli#second-brain","content":"Inspect the Second Brain self-model — what the app has learned about you — and\nverify it against the same guard the app uses, without opening the app."},"72":{"id":"/cli-29","page_id":"/cli","tags":[],"type":"text","url":"/cli#second-brain","content":"The output lists each belief with its salience, confidence, and evidence count,\nand reports how many would be kept versus dropped by the current guard. Add\n`--include-inactive` to also show dormant or retired beliefs."},"73":{"id":"/cli-30","page_id":"/cli","tags":[],"type":"text","url":"/cli#llm","content":"Run language-model tasks from the terminal. Unlike the app, the CLI is\nconfigured per call — you pass the provider and key on each invocation; nothing\nis stored."},"74":{"id":"/cli-31","page_id":"/cli","tags":[],"type":"text","url":"/cli#llm","content":"Supported providers: `anthropic`, `openai`, `openaiCompatible`, `gemini`,\n`openrouter`, `ollama`, `lmstudio`, `omlx`, and `cli` (a local subprocess)."},"75":{"id":"/cli-32","page_id":"/cli","tags":[],"type":"text","url":"/cli#llm","content":"How the key is resolved, in order: `--api-key` (a literal — discouraged), then\n`--api-key-env` (the name of an environment variable holding the key), then the\nconventional variable for the provider (for example `ANTHROPIC_API_KEY`,\n`OPENAI_API_KEY`, `GEMINI_API_KEY`, `OPENROUTER_API_KEY`). Local providers like\n`ollama` need no key."},"76":{"id":"/cli-33","page_id":"/cli","tags":[],"type":"text","url":"/cli#llm","content":"Other useful options:"},"77":{"id":"/cli-34","page_id":"/cli","tags":[],"type":"text","url":"/cli#llm","content":"`--model` — pick a model. Required for `openaiCompatible`, `lmstudio`, and\n`omlx`; other providers fall back to a conservative default."},"78":{"id":"/cli-35","page_id":"/cli","tags":[],"type":"text","url":"/cli#llm","content":"`--base-url` — an absolute `http(s)` URL for self-hosted endpoints."},"79":{"id":"/cli-36","page_id":"/cli","tags":[],"type":"text","url":"/cli#llm","content":"`--command` — the subprocess template, required for the `cli` provider."},"80":{"id":"/cli-37","page_id":"/cli","tags":[],"type":"text","url":"/cli#import","content":"Bring data over from an older version of the app. Import is read-only on the\nsource — your originals are never touched — and never runs automatically."},"81":{"id":"/cli-38","page_id":"/cli","tags":[],"type":"text","url":"/cli#import","content":"`--dry-run` shows the per-table counts (imported, skipped, unsupported) without\nwriting anything. Add `--json` for a structured report."},"82":{"id":"/cli-39","page_id":"/cli","tags":[],"type":"text","url":"/cli#json-output","content":"Pass `--json` to get stable, pretty-printed JSON with sorted keys and ISO-8601\ndates. Status text is kept off standard output, so you can pipe results\nstraight into other tools:"},"83":{"id":"/cli-40","page_id":"/cli","tags":[],"type":"text","url":"/cli#json-output","content":"On failure in `--json` mode, the tool prints an error envelope instead of the\nnormal payload:"},"84":{"id":"/cli-41","page_id":"/cli","tags":[],"type":"text","url":"/cli#json-output","content":"The `errorType` field comes from a small, stable vocabulary — for example\n`auth`, `config`, `connection`, `lookup`, `model`, `rate_limit`,\n`input_missing`, `input_empty`, and `validation` — so scripts can branch on the\nkind of failure."},"85":{"id":"/cli-42","page_id":"/cli","tags":[],"type":"text","url":"/cli#exit-codes","content":"`0` — success."},"86":{"id":"/cli-43","page_id":"/cli","tags":[],"type":"text","url":"/cli#exit-codes","content":"`1` — a runtime failure (network, provider, transcription, and similar)."},"87":{"id":"/cli-44","page_id":"/cli","tags":[],"type":"text","url":"/cli#exit-codes","content":"`2` — user misuse: bad arguments, a missing input file, or a lookup that was\nambiguous or too short."},"88":{"id":"/day-journal","page_id":"/day-journal","type":"page","content":"Day Journal","breadcrumbs":["Hindsight"],"tags":[],"url":"/day-journal"},"89":{"id":"/day-journal-0","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal","content":"Quiet on-device screenshots, on-device text recognition, an AI write-up of your day, and an end-of-day review — all kept on your Mac."},"90":{"id":"/day-journal-1","page_id":"/day-journal","type":"heading","tags":[],"url":"/day-journal#start-capturing","content":"Start capturing"},"91":{"id":"/day-journal-2","page_id":"/day-journal","type":"heading","tags":[],"url":"/day-journal#what-gets-captured","content":"What gets captured"},"92":{"id":"/day-journal-3","page_id":"/day-journal","type":"heading","tags":[],"url":"/day-journal#the-ai-day-narrative","content":"The AI day narrative"},"93":{"id":"/day-journal-4","page_id":"/day-journal","type":"heading","tags":[],"url":"/day-journal#the-end-of-day-review","content":"The end-of-day review"},"94":{"id":"/day-journal-5","page_id":"/day-journal","type":"heading","tags":[],"url":"/day-journal#pausing-capture","content":"Pausing capture"},"95":{"id":"/day-journal-6","page_id":"/day-journal","type":"heading","tags":[],"url":"/day-journal#keeping-and-clearing-screenshots","content":"Keeping and clearing screenshots"},"96":{"id":"/day-journal-7","page_id":"/day-journal","type":"heading","tags":[],"url":"/day-journal#todays-focus","content":"Today's Focus"},"97":{"id":"/day-journal-8","page_id":"/day-journal","type":"heading","tags":[],"url":"/day-journal#the-day-index","content":"The Day Index"},"98":{"id":"/day-journal-9","page_id":"/day-journal","type":"heading","tags":[],"url":"/day-journal#turning-through-your-days","content":"Turning through your days"},"99":{"id":"/day-journal-10","page_id":"/day-journal","type":"heading","tags":[],"url":"/day-journal#where-your-data-is-stored","content":"Where your data is stored"},"100":{"id":"/day-journal-11","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal","content":"The Day Journal is today's page in your book. While it runs, Hindsight quietly\ntakes a screenshot of your front window every couple of minutes, reads the text\non screen so you can recall anything you saw, and — when you stop for the day —\nwrites the day up for you to review and keep."},"101":{"id":"/day-journal-12","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#start-capturing","content":"Open the Day Journal control on today's page and press **Start**. The first time,\nmacOS needs the **Screen Recording** permission; grant it under\n**System Settings → Privacy & Security → Screen Recording**, then start again."},"102":{"id":"/day-journal-13","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#start-capturing","content":"While capture is running you'll see:"},"103":{"id":"/day-journal-14","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#start-capturing","content":"A **RECORDING** indicator with an elapsed clock."},"104":{"id":"/day-journal-15","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#start-capturing","content":"A running **FRAMES** count (screenshots taken so far)."},"105":{"id":"/day-journal-16","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#start-capturing","content":"A **MOMENTS** count. Press **Mark Moment** to flag something worth\nremembering as it happens; you can add a short note to a moment, too."},"106":{"id":"/day-journal-17","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#start-capturing","content":"To wrap up, press **Stop & Review**. **Discard** throws the session away."},"107":{"id":"/day-journal-18","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#what-gets-captured","content":"**Screenshots.** A frame of your front window, taken on-device at your chosen\ncadence. The default is **every 2 minutes** (you can pick 30 seconds, 1, 2, 5,\nor 10 minutes)."},"108":{"id":"/day-journal-19","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#what-gets-captured","content":"**On-screen text (OCR).** Each frame is read on-device so its text is\nsearchable and recallable. Recognition runs entirely on your Mac."},"109":{"id":"/day-journal-20","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#what-gets-captured","content":"**Context.** The app and window in front, so activities are easy to make sense\nof later."},"110":{"id":"/day-journal-21","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#what-gets-captured","content":"**Capture focused text (deep read)** reads the focused window's text through\nAccessibility for richer recall. It's off by default, stays on-device, and\nruns through the same redaction gate as everything else. Turn it on under\n**Settings → Capture** if you want it."},"111":{"id":"/day-journal-22","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#the-ai-day-narrative","content":"As the day goes on, Hindsight periodically reviews the new screenshots and keeps\na running summary of what you've been working on. The default is **every 30\nminutes** (you can choose 15, 30, or 60). When you stop, that work becomes the\nday's narrative — a short, readable write-up that sits on the finished day's\npage alongside a timeline of your activities, the apps you used, your marked\nmoments, and any notes you add."},"112":{"id":"/day-journal-23","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#the-ai-day-narrative","content":"The narrative is the one part that draws on an AI provider. Connect one under\n**Settings → AI Provider** — a local provider keeps everything on your Mac.\nCapture, text recognition, search, and storage never need a provider."},"113":{"id":"/day-journal-24","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#the-end-of-day-review","content":"After **Stop & Review**, Hindsight writes up your day and then opens a short\n**review** at the foot of today's page. It's a chat: it shows the running\nsummary, may ask a few follow-up questions to fill in gaps, and lets you add\nnotes. When you're happy, keep the day; or discard it. A kept day is saved as a\nfinished page you can turn back to anytime."},"114":{"id":"/day-journal-25","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#the-end-of-day-review","content":"Any finished day also has **Chat with this day** — a free-form conversation\nabout that single day, answered from what was captured."},"115":{"id":"/day-journal-26","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#pausing-capture","content":"Press **Pause** during a session to stop new screenshots for a while. You can\nnote why with a quick reason — **Meeting**, **Break**, **Lunch**, **Personal** —\nor type your own. Press **Resume** to start capturing again. The pause (and its\nreason) is recorded, so a finished day can show when and why capture was\ninterrupted."},"116":{"id":"/day-journal-27","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#pausing-capture","content":"Hindsight can also pause on its own:"},"117":{"id":"/day-journal-28","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#pausing-capture","content":"**Pause when idle** stops capturing when you step away. On by default, after\n**2 minutes** idle (you can choose 30 seconds, 1, or 2 minutes)."},"118":{"id":"/day-journal-29","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#pausing-capture","content":"**Reduce work on battery** lightens capture and analysis on battery power."},"119":{"id":"/day-journal-30","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#pausing-capture","content":"Both live under **Settings → Capture**."},"120":{"id":"/day-journal-31","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#keeping-and-clearing-screenshots","content":"Screenshots are pruned automatically by the **Keep screenshots for** setting —\n**30 days** by default, or 7, 90, or Forever. Lowering it deletes older captures\non its next pass; \"Forever\" never auto-deletes."},"121":{"id":"/day-journal-32","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#todays-focus","content":"On the right side of today's page, **Today's Focus** surfaces a few suggested\nto-dos drawn from your patterns — no AI provider needed:"},"122":{"id":"/day-journal-33","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#todays-focus","content":"**Open loops** — files or topics you touched then dropped (\"Close `plan.md` —\nyou touched it 8 days ago and haven't been back\")."},"123":{"id":"/day-journal-34","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#todays-focus","content":"**Cooling threads** — things that went quiet (\"Decide if the roadmap is still\nrelevant\")."},"124":{"id":"/day-journal-35","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#todays-focus","content":"**Meeting action items** — bullets extracted from your meeting transcripts'\n\"Action Items\" sections."},"125":{"id":"/day-journal-36","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#todays-focus","content":"You can **check one off**, **dismiss** it, or **Add to Notes** — which creates a\nchecklist note in Apple Notes with one click. (The first time, macOS asks for\nAutomation permission to control Notes; grant it once and it's automatic\nafterwards.)"},"126":{"id":"/day-journal-37","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#todays-focus","content":"When an AI provider is connected, the to-do titles are optionally rephrased into\nclearer imperative voice (\"Finish and close `plan.md`\") — but the detection\nitself is deterministic and always works, even offline."},"127":{"id":"/day-journal-38","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#todays-focus","content":"Today's Focus refreshes when you open the page and after you finish a day's\nreview."},"128":{"id":"/day-journal-39","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#the-day-index","content":"Press ⌘L anywhere to open the **Day Index** — a chronological overview\nof every captured day, newest first. Each row shows the day's title, date, frame\ncount, and a thumbnail of its most recent capture. Use ↑/↓\nto move and Return to turn straight to a day. A density strip at the\ntop shows how many days you've captured and the span of your history."},"129":{"id":"/day-journal-40","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#turning-through-your-days","content":"Use the left and right arrows to turn between days. The red Ribbon always brings\nyou back to today, and **Turn to today** is also available from the Index\n(⌘K, shortcut T)."},"130":{"id":"/day-journal-41","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#where-your-data-is-stored","content":"Everything stays on this Mac, under your Library:"},"131":{"id":"/day-journal-42","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#where-your-data-is-stored","content":"**Screenshots:** `~/Library/Application Support/HindsightNext/journal`"},"132":{"id":"/day-journal-43","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#where-your-data-is-stored","content":"**Journal database** (text, timeline, narratives, notes):\n`~/Library/Application Support/HindsightNext/hindsight.db`"},"133":{"id":"/day-journal-44","page_id":"/day-journal","tags":[],"type":"text","url":"/day-journal#where-your-data-is-stored","content":"Capture and text recognition happen on-device, and nothing leaves your Mac\nunless you choose to connect an AI provider for the narrative or for chat."},"134":{"id":"/export","page_id":"/export","type":"page","content":"Export","breadcrumbs":["Hindsight"],"tags":[],"url":"/export"},"135":{"id":"/export-0","page_id":"/export","tags":[],"type":"text","url":"/export","content":"Materialize your knowledge as an Obsidian-style vault of linked Markdown notes, or as a knowledge graph in GraphML and Mermaid. Everything stays on your Mac."},"136":{"id":"/export-1","page_id":"/export","type":"heading","tags":[],"url":"/export#export-an-obsidian-vault","content":"Export an Obsidian vault"},"137":{"id":"/export-2","page_id":"/export","type":"heading","tags":[],"url":"/export#export-a-graph","content":"Export a graph"},"138":{"id":"/export-3","page_id":"/export","type":"heading","tags":[],"url":"/export#where-the-files-land","content":"Where the files land"},"139":{"id":"/export-4","page_id":"/export","type":"heading","tags":[],"url":"/export#before-you-export","content":"Before you export"},"140":{"id":"/export-5","page_id":"/export","tags":[],"type":"text","url":"/export","content":"Export turns what Hindsight has already captured into open, portable files you\ncan browse, link, and visualize in other tools. Nothing new leaves your machine\n— export only writes out the on-device, redacted data you can already see in the\napp. The database stays the source of truth; export is a one-way snapshot you can\nre-run any time."},"141":{"id":"/export-6","page_id":"/export","tags":[],"type":"text","url":"/export","content":"You'll find it in the Second Brain. Open it from the Index (⌘K) and\ngo to the **Export** tab (⌘4)."},"142":{"id":"/export-7","page_id":"/export","tags":[],"type":"text","url":"/export#export-an-obsidian-vault","content":"**Export Obsidian vault** writes your whole journal as a folder of linked\nMarkdown notes — the kind of vault Obsidian, Logseq, or any plain-Markdown editor\ncan open directly."},"143":{"id":"/export-8","page_id":"/export","tags":[],"type":"text","url":"/export#export-an-obsidian-vault","content":"Each completed day becomes a daily note, and the people, sites, and files you\nencountered become their own notes, joined together with `[[wikilinks]]` so the\nwhole thing browses as a connected web."},"144":{"id":"/export-9","page_id":"/export","tags":[],"type":"text","url":"/export#export-an-obsidian-vault","content":"What you get:"},"145":{"id":"/export-10","page_id":"/export","tags":[],"type":"text","url":"/export#export-an-obsidian-vault","content":"**Days/** — one note per captured day, with the day's narrative, a timeline of\nwhat you worked on, and linked lists of the **People**, **Links**, and **Files**\nseen that day. Your own notes for the day come along too. Each note carries\nfrontmatter (`date`, `captures`, `tags`)."},"146":{"id":"/export-11","page_id":"/export","tags":[],"type":"text","url":"/export#export-an-obsidian-vault","content":"**People/** — one note per person, built from the email addresses in your\nhistory. Addresses are humanized into names (`jane.smith@example.com` becomes\n*Jane Smith*), and OCR variants of the same address collapse into a single\nnote. Each note lists the days that person showed up."},"147":{"id":"/export-12","page_id":"/export","tags":[],"type":"text","url":"/export#export-an-obsidian-vault","content":"**Links/** — one note per web address you returned to, backlinked to the days\nit appeared."},"148":{"id":"/export-13","page_id":"/export","tags":[],"type":"text","url":"/export#export-an-obsidian-vault","content":"**Files/** — one note per file, backlinked to the days it appeared."},"149":{"id":"/export-14","page_id":"/export","tags":[],"type":"text","url":"/export#export-an-obsidian-vault","content":"**Topics/** — \"area\" notes for the clusters Hindsight detected in your graph,\neach linking its members."},"150":{"id":"/export-15","page_id":"/export","tags":[],"type":"text","url":"/export#export-an-obsidian-vault","content":"**GRAPH\\_REPORT.md** — a map-of-content for the vault: your most-connected\nnodes, surprising connections, and a few questions worth exploring, all\nresolving to the notes above."},"151":{"id":"/export-16","page_id":"/export","tags":[],"type":"text","url":"/export#export-an-obsidian-vault","content":"Only completed days are included, and every note is plain Markdown — no lock-in.\nRe-running the export refreshes the vault in place."},"152":{"id":"/export-17","page_id":"/export","tags":[],"type":"text","url":"/export#export-a-graph","content":"**Export graph (GraphML + Mermaid)** writes your knowledge graph — the people,\nsites, and files that recur together — in two visualization-ready formats:"},"153":{"id":"/export-18","page_id":"/export","tags":[],"type":"text","url":"/export#export-a-graph","content":"**graph.graphml** — open it in yEd,\nGephi, or Obsidian's graph plugins for an interactive,\nlaid-out view."},"154":{"id":"/export-19","page_id":"/export","tags":[],"type":"text","url":"/export#export-a-graph","content":"**graph.mermaid** — a Mermaid `graph TD` diagram you\ncan paste straight into Markdown, Obsidian, or Notion, or render at\nmermaid.live."},"155":{"id":"/export-20","page_id":"/export","tags":[],"type":"text","url":"/export#export-a-graph","content":"Both are derived from the same recurring-node snapshot the Second Brain's Network\ntab already shows: nodes are the things you keep returning to, and edges are the\nlinks between things that keep appearing together (weighted by how strong the\nconnection is)."},"156":{"id":"/export-21","page_id":"/export","tags":[],"type":"text","url":"/export#where-the-files-land","content":"By default both exports write inside Hindsight's own folder:"},"157":{"id":"/export-22","page_id":"/export","tags":[],"type":"text","url":"/export#where-the-files-land","content":"**Obsidian vault** — `~/Library/Application Support/Hindsight/ObsidianVault/`"},"158":{"id":"/export-23","page_id":"/export","tags":[],"type":"text","url":"/export#where-the-files-land","content":"**Graph files** — `~/Library/Application Support/Hindsight/GraphExport/`"},"159":{"id":"/export-24","page_id":"/export","tags":[],"type":"text","url":"/export#where-the-files-land","content":"After an export runs, a **Reveal in Finder** button appears next to it — the\nquickest way to jump to the files. The status line below the buttons confirms\nwhat was written (for example, &#x2A;Exported 12 days · 34 people · 18 links · 9\nfiles.* for the vault, or *Exported graph · 60 nodes · 142 edges* for the graph)."},"160":{"id":"/export-25","page_id":"/export","tags":[],"type":"text","url":"/export#before-you-export","content":"Export needs something to materialize, so journal a few days first. If there's\nnothing to write yet, Hindsight tells you so rather than creating an empty vault."},"161":{"id":"/export-26","page_id":"/export","tags":[],"type":"text","url":"/export#before-you-export","content":"Export is fully local. It reuses only the redacted, on-device data Hindsight\nhas already captured — secrets such as card numbers, keys, and one-time codes\nare never turned into notes — and nothing is sent anywhere. The files are yours\nto move, edit, and back up however you like."},"162":{"id":"/getting-started","page_id":"/getting-started","type":"page","content":"Getting started","breadcrumbs":["Hindsight"],"tags":[],"url":"/getting-started"},"163":{"id":"/getting-started-0","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started","content":"Install Hindsight, run first-time setup, and grant Screen Recording on recent macOS."},"164":{"id":"/getting-started-1","page_id":"/getting-started","type":"heading","tags":[],"url":"/getting-started#requirements","content":"Requirements"},"165":{"id":"/getting-started-2","page_id":"/getting-started","type":"heading","tags":[],"url":"/getting-started#install","content":"Install"},"166":{"id":"/getting-started-3","page_id":"/getting-started","type":"heading","tags":[],"url":"/getting-started#first-time-setup","content":"First-time setup"},"167":{"id":"/getting-started-4","page_id":"/getting-started","type":"heading","tags":[],"url":"/getting-started#1-welcome","content":"1\\. Welcome"},"168":{"id":"/getting-started-5","page_id":"/getting-started","type":"heading","tags":[],"url":"/getting-started#2-set-up-the-day-journal","content":"2\\. Set up the Day Journal"},"169":{"id":"/getting-started-6","page_id":"/getting-started","type":"heading","tags":[],"url":"/getting-started#3-microphone-access-optional","content":"3\\. Microphone access (optional)"},"170":{"id":"/getting-started-7","page_id":"/getting-started","type":"heading","tags":[],"url":"/getting-started#4-prepare-on-device-models","content":"4\\. Prepare on-device models"},"171":{"id":"/getting-started-8","page_id":"/getting-started","type":"heading","tags":[],"url":"/getting-started#5-three-moves-one-rehearsal","content":"5\\. Three moves, one rehearsal"},"172":{"id":"/getting-started-9","page_id":"/getting-started","type":"heading","tags":[],"url":"/getting-started#6-ready","content":"6\\. Ready"},"173":{"id":"/getting-started-10","page_id":"/getting-started","type":"heading","tags":[],"url":"/getting-started#granting-screen-recording-on-recent-macos","content":"Granting Screen Recording on recent macOS"},"174":{"id":"/getting-started-11","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#requirements","content":"**macOS 14.2 or later.**"},"175":{"id":"/getting-started-12","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#requirements","content":"**Apple Silicon** (M-series). The on-device speech model runs on the Neural\nEngine, so an Apple Silicon Mac is required."},"176":{"id":"/getting-started-13","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#requirements","content":"A few gigabytes of free disk space for the speech model, which downloads once\nduring setup."},"177":{"id":"/getting-started-14","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#install","content":"Download the latest `Hindsight.dmg` from the\nReleases page."},"178":{"id":"/getting-started-15","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#install","content":"Open the DMG and drag **Hindsight** onto the **Applications** folder shortcut."},"179":{"id":"/getting-started-16","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#install","content":"Open **Hindsight** from Applications."},"180":{"id":"/getting-started-17","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#install","content":"Hindsight keeps itself up to date, and you can trigger a check yourself from the\nColophon under **The Apparatus → Check for updates**."},"181":{"id":"/getting-started-18","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#first-time-setup","content":"The first time you open Hindsight, it opens a first-run setup that walks you\nthrough a few short steps. A &#x2A;*Step *n* of *N*** counter sits in the top-right,\nand you can step back at any time with the chevron. Permission steps are\noptional and can be skipped with **Skip — I'll set this up later**; only the\non-device model step has to finish before you continue."},"182":{"id":"/getting-started-19","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#1-welcome","content":"A quick tour of what Hindsight is: a **Day Journal** woven from periodic screen\ncapture, on-device meeting recording, and a design that keeps your data on this\nMac. Press **Get Started**."},"183":{"id":"/getting-started-20","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#2-set-up-the-day-journal","content":"The Day Journal periodically captures your screen and reads it with on-device\nOCR to weave a private narrative of your day. Screenshots never leave your Mac."},"184":{"id":"/getting-started-21","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#2-set-up-the-day-journal","content":"This step asks for the **Screen & System Audio Recording** permission. Press\n**Enable Day Journal**, then toggle Hindsight on in the System Settings pane\nthat opens. The same grant also covers meeting recording later, so you only\ngrant it once. See Granting Screen Recording\nbelow if the status doesn't update right away."},"185":{"id":"/getting-started-22","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#2-set-up-the-day-journal","content":"The microphone is **not** required for journaling — you can skip the next step\nand the Day Journal still works."},"186":{"id":"/getting-started-23","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#3-microphone-access-optional","content":"The microphone is only used for **meeting** capture. Grant it now if you plan to\nrecord meetings, or skip it and enable it later from the Colophon."},"187":{"id":"/getting-started-24","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#4-prepare-on-device-models","content":"Hindsight downloads and optimizes the speech model on this Mac so meetings can\nbe transcribed locally — **audio never leaves your machine**. You'll see a\nprogress bar while the model downloads and warms up. This is the one step you\ncan't skip: **Continue** stays disabled until the model reports\n&#x2A;*Speech model is ready.**"},"188":{"id":"/getting-started-25","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#4-prepare-on-device-models","content":"This download happens once. If a future launch already has the model cached, the\nstep finishes instantly. If setup stalls (for example, on a slow network), use\n**Retry**."},"189":{"id":"/getting-started-26","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#5-three-moves-one-rehearsal","content":"Before you finish, Hindsight has you rehearse the three ways you move through\nyour book:"},"190":{"id":"/getting-started-27","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#5-three-moves-one-rehearsal","content":"**Turn** — the left and right arrows move between days."},"191":{"id":"/getting-started-28","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#5-three-moves-one-rehearsal","content":"**The Index** — ⌘K goes anywhere: days, minutes, settings."},"192":{"id":"/getting-started-29","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#5-three-moves-one-rehearsal","content":"**The Ribbon** — the red mark always brings you back to today."},"193":{"id":"/getting-started-30","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#5-three-moves-one-rehearsal","content":"Press ⌘K once when prompted to summon the Index, then press\nReturn to finish."},"194":{"id":"/getting-started-31","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#6-ready","content":"Press **Open Hindsight** and you're in. You'll land on today's page in your\nDay Journal."},"195":{"id":"/getting-started-32","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#granting-screen-recording-on-recent-macos","content":"The Day Journal and meeting recording both rely on the **Screen & System Audio\nRecording** permission. On recent macOS, granting it has one quirk worth knowing."},"196":{"id":"/getting-started-33","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#granting-screen-recording-on-recent-macos","content":"In the setup step, press **Enable Day Journal** (or **Open System Settings**).\nThis adds Hindsight to the list and opens\n**System Settings → Privacy & Security → Screen & System Audio Recording**."},"197":{"id":"/getting-started-34","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#granting-screen-recording-on-recent-macos","content":"**Toggle Hindsight on.** On recent macOS there's no confirmation dialog —\nflipping the toggle is the grant."},"198":{"id":"/getting-started-35","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#granting-screen-recording-on-recent-macos","content":"**Relaunch Hindsight.** macOS only applies this permission when the app\nstarts, so the status may keep reading *Not granted* until you quit and\nreopen. Setup will prompt you to relaunch if it notices the grant hasn't\ntaken effect yet."},"199":{"id":"/getting-started-36","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#granting-screen-recording-on-recent-macos","content":"If the Hindsight entry doesn't respond, remove it from the list and re-add\n`/Applications/Hindsight.app&#x60; with the &#x2A;*+** button, then relaunch."},"200":{"id":"/getting-started-37","page_id":"/getting-started","tags":[],"type":"text","url":"/getting-started#granting-screen-recording-on-recent-macos","content":"You can revisit any of this later. Screen Recording, microphone, and calendar\naccess can all be re-checked and changed from the **Colophon** (open the Index\nwith ⌘K → **Colophon**)."},"201":{"id":"/","page_id":"/","type":"page","content":"Welcome","breadcrumbs":["Hindsight"],"tags":[],"url":"/"},"202":{"id":"/-0","page_id":"/","tags":[],"type":"text","url":"/","content":"Hindsight is a private, on-device daybook for macOS — a day journal, your meetings, and a second brain, all kept on your machine."},"203":{"id":"/-1","page_id":"/","type":"heading","tags":[],"url":"/#the-three-pillars","content":"The three pillars"},"204":{"id":"/-2","page_id":"/","type":"heading","tags":[],"url":"/#day-journal","content":"Day Journal"},"205":{"id":"/-3","page_id":"/","type":"heading","tags":[],"url":"/#the-minutes","content":"The Minutes"},"206":{"id":"/-4","page_id":"/","type":"heading","tags":[],"url":"/#second-brain","content":"Second Brain"},"207":{"id":"/-5","page_id":"/","type":"heading","tags":[],"url":"/#privacy","content":"Privacy"},"208":{"id":"/-6","page_id":"/","type":"heading","tags":[],"url":"/#get-started","content":"Get started"},"209":{"id":"/-7","page_id":"/","tags":[],"type":"text","url":"/","content":"Hindsight is a private daybook for your Mac. It is one continuous book you turn\nthrough, page by page: a **Day Journal** for what you worked on, **The Minutes**\nfor your meetings, and a **Second Brain** that learns from your history and can\ntalk it back to you."},"210":{"id":"/-8","page_id":"/","tags":[],"type":"text","url":"/","content":"The window is page-based. Turn left and right between days, jump anywhere with\nthe Index (⌘K), and let the red Ribbon bring you back to today.\nEverything you capture stays on this Mac."},"211":{"id":"/-9","page_id":"/","tags":[],"type":"text","url":"/#day-journal","content":"The Day Journal is today's page in your book — a running record of what you did,\nso you can reflect on your decisions later. Turn between days with the left and\nright arrows, and use **Ask the book** on any page to pose a question about your\nday or your history."},"212":{"id":"/-10","page_id":"/","tags":[],"type":"text","url":"/#day-journal","content":"Read more about the Day Journal →"},"213":{"id":"/-11","page_id":"/","tags":[],"type":"text","url":"/#the-minutes","content":"The Minutes records and transcribes your meetings on-device. Start a recording\nfrom the Index or with ⇧⌘M; Hindsight can also watch your calendar\nand offer to begin minutes when a meeting starts, recognizing Google Meet, Zoom,\nand Microsoft Teams links. Finished meetings are saved to your Library with a\ntitle you can rename."},"214":{"id":"/-12","page_id":"/","tags":[],"type":"text","url":"/#the-minutes","content":"Read more about The Minutes →"},"215":{"id":"/-13","page_id":"/","tags":[],"type":"text","url":"/#second-brain","content":"The Second Brain learns from what you capture. Chat with your history, browse\nthe Insights it has noticed, explore the Network of how people, projects, and\nideas connect, and Export what you find — including drafting an email or a\ncalendar event from the conversation."},"216":{"id":"/-14","page_id":"/","tags":[],"type":"text","url":"/#second-brain","content":"Read more about the Second Brain →"},"217":{"id":"/-15","page_id":"/","tags":[],"type":"text","url":"/#privacy","content":"Hindsight is on-device by default:"},"218":{"id":"/-16","page_id":"/","tags":[],"type":"text","url":"/#privacy","content":"**Capture, transcription, and storage stay local.** Meetings are transcribed\non your Mac, and your journal database never leaves it."},"219":{"id":"/-17","page_id":"/","tags":[],"type":"text","url":"/#privacy","content":"**No AI traffic without a provider you choose.** If you don't connect an AI\nprovider, nothing is sent anywhere — Ask the book and the Second Brain simply\nwait until one is configured."},"220":{"id":"/-18","page_id":"/","tags":[],"type":"text","url":"/#privacy","content":"**A local provider keeps everything on your machine.** Connect Ollama or\nLM Studio and your text is processed locally, with no calls off the Mac."},"221":{"id":"/-19","page_id":"/","tags":[],"type":"text","url":"/#privacy","content":"**Cloud is opt-in.** Sending your journal to a cloud provider is off until you\nexplicitly turn it on, and the same gate applies uniformly to journal text,\nmeeting transcripts, chat, and drafts."},"222":{"id":"/-20","page_id":"/","tags":[],"type":"text","url":"/#get-started","content":"Head to Getting started to install Hindsight, run\nfirst-time setup, and learn the three moves for turning through your book."},"223":{"id":"/meetings","page_id":"/meetings","type":"page","content":"Meetings","breadcrumbs":["Hindsight"],"tags":[],"url":"/meetings"},"224":{"id":"/meetings-0","page_id":"/meetings","tags":[],"type":"text","url":"/meetings","content":"Record and transcribe meetings on-device, with a live panel, notes, and an AI Ask tab."},"225":{"id":"/meetings-1","page_id":"/meetings","type":"heading","tags":[],"url":"/meetings#start-a-recording","content":"Start a recording"},"226":{"id":"/meetings-2","page_id":"/meetings","type":"heading","tags":[],"url":"/meetings#microphone-and-system-audio","content":"Microphone and system audio"},"227":{"id":"/meetings-3","page_id":"/meetings","type":"heading","tags":[],"url":"/meetings#the-live-panel","content":"The live panel"},"228":{"id":"/meetings-4","page_id":"/meetings","type":"heading","tags":[],"url":"/meetings#extracting-todos-from-a-meeting","content":"Extracting todos from a meeting"},"229":{"id":"/meetings-5","page_id":"/meetings","type":"heading","tags":[],"url":"/meetings#hiding-speakers","content":"Hiding speakers"},"230":{"id":"/meetings-6","page_id":"/meetings","type":"heading","tags":[],"url":"/meetings#the-floating-pill","content":"The floating pill"},"231":{"id":"/meetings-7","page_id":"/meetings","type":"heading","tags":[],"url":"/meetings#ask-during-a-meeting","content":"Ask during a meeting"},"232":{"id":"/meetings-8","page_id":"/meetings","type":"heading","tags":[],"url":"/meetings#after-a-meeting","content":"After a meeting"},"233":{"id":"/meetings-9","page_id":"/meetings","type":"heading","tags":[],"url":"/meetings#run-a-summary-automatically","content":"Run a summary automatically"},"234":{"id":"/meetings-10","page_id":"/meetings","type":"heading","tags":[],"url":"/meetings#privacy","content":"Privacy"},"235":{"id":"/meetings-11","page_id":"/meetings","tags":[],"type":"text","url":"/meetings","content":"Meetings is where Hindsight records, transcribes, and summarizes your\nconversations. Recording and transcription happen on-device. Each finished\nmeeting is saved alongside your days so you can revisit it later."},"236":{"id":"/meetings-12","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#start-a-recording","content":"There are three ways to begin:"},"237":{"id":"/meetings-13","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#start-a-recording","content":"**Record tile** — open the **Meetings** page (or the daybook's Today page)\nand click **Record** on the \"Record a meeting\" tile."},"238":{"id":"/meetings-14","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#start-a-recording","content":"**Hotkey** — press ⇧⌘M from anywhere. The same shortcut stops the\nrecording when you're done."},"239":{"id":"/meetings-15","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#start-a-recording","content":"**Menu bar** — click the Hindsight status item and choose **Start Recording**."},"240":{"id":"/meetings-16","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#start-a-recording","content":"You can also begin from the Index: ⌘K → **Begin minutes**."},"241":{"id":"/meetings-17","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#start-a-recording","content":"When you start, Hindsight checks for Microphone and Screen Recording access. If\neither is missing, it points you to System Settings. The first time, grant both\nso capture can run."},"242":{"id":"/meetings-18","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#microphone-and-system-audio","content":"By default Hindsight records two streams at once — your **microphone** and your\nMac's **system audio** (the other people on the call) — and keeps them as\nseparate, time-aligned tracks."},"243":{"id":"/meetings-19","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#microphone-and-system-audio","content":"Choose the default for new recordings under **Settings → Audio sources**:"},"244":{"id":"/meetings-20","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#microphone-and-system-audio","content":"**Microphone + System Audio** (default) — records your voice and the call\ntogether."},"245":{"id":"/meetings-21","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#microphone-and-system-audio","content":"**System Audio Only** — captures just what's playing on your Mac, with no\nmicrophone. Use this for recordings where your own voice isn't needed."},"246":{"id":"/meetings-22","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#microphone-and-system-audio","content":"The microphone **Mute** control is available only in Microphone + System Audio\nmode."},"247":{"id":"/meetings-23","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#the-live-panel","content":"Click the floating pill to open the meeting panel. The header shows whether\nyou're **Recording** or **Paused**, the elapsed time, and live level meters for\nthe microphone and system audio."},"248":{"id":"/meetings-24","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#the-live-panel","content":"From the header you can:"},"249":{"id":"/meetings-25","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#the-live-panel","content":"**Mute / Unmute** the microphone (mic + system mode only). Muting also pauses\nlive transcription of your voice."},"250":{"id":"/meetings-26","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#the-live-panel","content":"**Pause / Resume** — pausing stops capture without leaving a gap; the saved\naudio plays back seamlessly."},"251":{"id":"/meetings-27","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#the-live-panel","content":"**Stop** — ends the meeting and starts transcription."},"252":{"id":"/meetings-28","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#the-live-panel","content":"The panel has three tabs, switchable with ⌘1–⌘3:"},"253":{"id":"/meetings-29","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#the-live-panel","content":"**Notes** (default) — type your own notes as the meeting runs. They're saved\ncontinuously. An **Insert** menu adds quick snippets like `/decision`,\n`/action`, and `/question`."},"254":{"id":"/meetings-30","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#the-live-panel","content":"**Transcript** — the live, speaker-labeled transcript. Toggle **Auto-scroll**\nor **Copy** the text so far."},"255":{"id":"/meetings-31","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#the-live-panel","content":"**Ask** — put a question to an AI provider about the conversation as it\nhappens (see below)."},"256":{"id":"/meetings-32","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#extracting-todos-from-a-meeting","content":"A **checklist button** (✓) in the meeting header reads the transcript and\nextracts action items — things you said you'd do, were asked to do, or agreed\nto. They land in **Today's Focus** immediately, each tagged with the meeting\nthey came from. You'll see them on the Today page."},"257":{"id":"/meetings-33","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#extracting-todos-from-a-meeting","content":"This also happens **automatically** when a meeting finishes — you don't have to\npress the button. But if you edit the transcript, hide a speaker, or just want\nto re-extract, the button is there."},"258":{"id":"/meetings-34","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#hiding-speakers","content":"Sometimes you want to share a transcript without your own voice in it — or\nwithout a noisy participant. In any saved meeting:"},"259":{"id":"/meetings-35","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#hiding-speakers","content":"**Hide my voice** — a one-click toggle at the top of the transcript removes\nyour turns from the view. Nothing is destroyed; bring them back anytime with\nthe same toggle."},"260":{"id":"/meetings-36","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#hiding-speakers","content":"**Hide any speaker** — the **Speakers** tab (⌘4 in the detail view)\nshows each participant's talk share. Click **Hide from transcript** on any\nspeaker to remove their turns. Hidden speakers appear in a **Hidden** section\nwith **Unhide** and **Unhide all** controls."},"261":{"id":"/meetings-37","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#hiding-speakers","content":"Hiding persists across re-analysis — if you re-run speaker detection later (to\npick up model improvements), the people you hid stay hidden."},"262":{"id":"/meetings-38","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#the-floating-pill","content":"While a meeting is active, a small pill floats on top of every app. It pulses\nwith your audio levels while recording, dims with pause bars when paused, shows\na spinner while transcribing, and a checkmark when the meeting is saved."},"263":{"id":"/meetings-39","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#the-floating-pill","content":"**Click** the pill to open the panel."},"264":{"id":"/meetings-40","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#the-floating-pill","content":"**Right-click** for **Stop**, **Pause / Resume**, **Open**, and **Cancel**.\nCancel discards the recording and deletes its audio, so it asks you to confirm\nfirst."},"265":{"id":"/meetings-41","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#ask-during-a-meeting","content":"The **Ask** tab lets you query an AI provider about the live transcript and your\nnotes without leaving the call. The empty state offers browsable quick prompts\ngrouped under **Catch Up**, **Capture**, and **Challenge** — for example\n\"Summarize so far\", \"Action items\", and \"What should I ask?\". Pinned follow-ups\nlike \"Tell me more\" and \"Counter-argument?\" sit above the input once a thread\nis going."},"266":{"id":"/meetings-42","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#ask-during-a-meeting","content":"Your Ask conversation carries over to the saved meeting, so you can keep working\nwith it afterward."},"267":{"id":"/meetings-43","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#ask-during-a-meeting","content":"Ask needs an AI provider; recording and transcription work without one.\nConnect a provider under **Settings → AI Provider** — a local provider keeps\neverything on your Mac."},"268":{"id":"/meetings-44","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#after-a-meeting","content":"When you press **Stop**, Hindsight transcribes the audio on-device and saves the\nmeeting to your **Recent meetings** list. The pill confirms with a checkmark and\nclears itself shortly after."},"269":{"id":"/meetings-45","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#after-a-meeting","content":"A saved meeting keeps its transcript, your notes, and any Ask conversation. You\ncan:"},"270":{"id":"/meetings-46","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#after-a-meeting","content":"**Rename** it from the title."},"271":{"id":"/meetings-47","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#after-a-meeting","content":"Run **prompt templates** against it — Summary, Action Items & Decisions,\nChapter Breakdown, and more."},"272":{"id":"/meetings-48","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#after-a-meeting","content":"Continue the **chat** about it from the meeting's page."},"273":{"id":"/meetings-49","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#after-a-meeting","content":"**Save Audio** to export the recording."},"274":{"id":"/meetings-50","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#run-a-summary-automatically","content":"Turn on **Run marked prompts automatically** under \"After each meeting\" to have\nchosen templates (the **Summary** template is marked by default) run as soon as\na meeting finishes. Because this sends the transcript to your AI provider, it's\noff until you switch it on. Use &#x2A;*Edit Prompts…** to add, pin, hide, or reset\nthe built-in prompts."},"275":{"id":"/meetings-51","page_id":"/meetings","tags":[],"type":"text","url":"/meetings#privacy","content":"Capture and transcription run entirely on your Mac. AI features — Ask, prompt\ntemplates, and auto-summaries — only reach out when you've connected a provider,\nand a local provider keeps everything on-device."},"276":{"id":"/privacy","page_id":"/privacy","type":"page","content":"Privacy","breadcrumbs":["Hindsight"],"tags":[],"url":"/privacy"},"277":{"id":"/privacy-0","page_id":"/privacy","tags":[],"type":"text","url":"/privacy","content":"How Hindsight keeps your data on-device by default, how optional cloud AI is gated by consent and redacted before it leaves your Mac, and where to configure a provider and keys."},"278":{"id":"/privacy-1","page_id":"/privacy","type":"heading","tags":[],"url":"/privacy#on-device-by-default","content":"On-device by default"},"279":{"id":"/privacy-2","page_id":"/privacy","type":"heading","tags":[],"url":"/privacy#ai-is-opt-in","content":"AI is opt-in"},"280":{"id":"/privacy-3","page_id":"/privacy","type":"heading","tags":[],"url":"/privacy#prompts-are-redacted-before-any-cloud-call","content":"Prompts are redacted before any cloud call"},"281":{"id":"/privacy-4","page_id":"/privacy","type":"heading","tags":[],"url":"/privacy#optional-features-that-can-send-more","content":"Optional features that can send more"},"282":{"id":"/privacy-5","page_id":"/privacy","type":"heading","tags":[],"url":"/privacy#local-ai-sees-the-real-thing","content":"Local AI sees the real thing"},"283":{"id":"/privacy-6","page_id":"/privacy","type":"heading","tags":[],"url":"/privacy#every-answer-is-verified","content":"Every answer is verified"},"284":{"id":"/privacy-7","page_id":"/privacy","type":"heading","tags":[],"url":"/privacy#where-to-configure-it-the-colophon","content":"Where to configure it: the Colophon"},"285":{"id":"/privacy-8","page_id":"/privacy","type":"heading","tags":[],"url":"/privacy#where-your-keys-are-stored","content":"Where your keys are stored"},"286":{"id":"/privacy-9","page_id":"/privacy","tags":[],"type":"text","url":"/privacy","content":"Hindsight is built to stay on your Mac. Capture, transcription, the knowledge\ngraph, and your whole journal database live locally, and nothing is sent to an AI\nunless you connect a provider and — for cloud providers — explicitly turn cloud\nanalysis on. This page explains exactly what stays put, what can leave, and how\nto control it."},"287":{"id":"/privacy-10","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#on-device-by-default","content":"Out of the box, everything happens on your machine:"},"288":{"id":"/privacy-11","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#on-device-by-default","content":"**Screen capture and OCR.** The Day Journal periodically captures your screen\nand reads it with on-device OCR. Screenshots are processed and stored locally\nand never uploaded."},"289":{"id":"/privacy-12","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#on-device-by-default","content":"**Meeting transcription.** Meetings are transcribed by an on-device speech\nmodel. Audio never leaves your Mac."},"290":{"id":"/privacy-13","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#on-device-by-default","content":"**Your journal and graph.** The journal database, the people, files, sites,\nand beliefs in the Second Brain, and your meeting library are all stored on\nthis Mac."},"291":{"id":"/privacy-14","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#on-device-by-default","content":"**Insights, Network, and beliefs.** These are computed deterministically from\nyour own history on-device, so they work with no AI provider connected at all."},"292":{"id":"/privacy-15","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#on-device-by-default","content":"By default, **journal entries are kept for 30 days** and then pruned. You can\nchange retention (7, 30, 90 days, or Forever) in the Colophon."},"293":{"id":"/privacy-16","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#ai-is-opt-in","content":"Hindsight never talks to an AI provider unless you set one up:"},"294":{"id":"/privacy-17","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#ai-is-opt-in","content":"**No provider, no traffic.** If you haven't configured a provider, features\nthat use AI — Ask the book, Second Brain chat, drafting — simply wait. Nothing\nis sent anywhere."},"295":{"id":"/privacy-18","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#ai-is-opt-in","content":"**Local providers keep everything on your Mac.** Connect a local model runner\n(Ollama, LM Studio, oMLX, or any OpenAI-compatible endpoint on `localhost`)\nand your text is processed on your machine, with no calls off the Mac."},"296":{"id":"/privacy-19","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#ai-is-opt-in","content":"**Cloud providers are gated by consent.** A cloud provider (Anthropic, OpenAI,\nGoogle Gemini, OpenRouter) is only allowed to receive your data after you turn\non **Allow cloud AI to analyze your journal**, which is **off by default**."},"297":{"id":"/privacy-20","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#ai-is-opt-in","content":"Every AI feature passes the same check before anything is sent: if no provider\nis configured the call is declined, a local provider is allowed, and a cloud\nprovider is allowed only with your consent. There is no separate path — journal\ntext, meeting transcripts, chat questions, drafts, and image descriptions all go\nthrough the same gate."},"298":{"id":"/privacy-21","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#prompts-are-redacted-before-any-cloud-call","content":"Before any text is sent to a provider, Hindsight runs an offline,\non-device pass that scrubs secrets out of it. This runs both at capture time\n(before anything is written to your journal) and again before every outbound AI\ncall. It recognizes:"},"299":{"id":"/privacy-22","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#prompts-are-redacted-before-any-cloud-call","content":"Private keys"},"300":{"id":"/privacy-23","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#prompts-are-redacted-before-any-cloud-call","content":"JSON Web Tokens (JWTs)"},"301":{"id":"/privacy-24","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#prompts-are-redacted-before-any-cloud-call","content":"API keys"},"302":{"id":"/privacy-25","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#prompts-are-redacted-before-any-cloud-call","content":"Bearer tokens"},"303":{"id":"/privacy-26","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#prompts-are-redacted-before-any-cloud-call","content":"Payment card numbers"},"304":{"id":"/privacy-27","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#prompts-are-redacted-before-any-cloud-call","content":"Social Security numbers"},"305":{"id":"/privacy-28","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#prompts-are-redacted-before-any-cloud-call","content":"One-time passcodes (OTPs)"},"306":{"id":"/privacy-29","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#prompts-are-redacted-before-any-cloud-call","content":"Each match is replaced inline with a placeholder like `[REDACTED:api_key]`. The\nmatched secret itself is never shown in the app and never leaves your Mac. The\nredaction pass is pure and offline — it makes no network calls of its own."},"307":{"id":"/privacy-30","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#optional-features-that-can-send-more","content":"These are all **off by default** and each is independently controlled in the\nColophon:"},"308":{"id":"/privacy-31","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#optional-features-that-can-send-more","content":"**External agents (MCP).** Lets an external AI agent query your journal\nlocally. It exposes only the structured, already-redacted recall — people,\nfiles, links, and graph — never screenshots. Exposing raw screen text\n(full-text search) is a separate, extra opt-in, and turning the agent server\noff revokes it."},"309":{"id":"/privacy-32","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#optional-features-that-can-send-more","content":"A related option, **AI refinement of insights**, is on by default once a\nprovider is configured. It lets the connected AI tidy your beliefs and topics;\nturn it off to keep the plain, deterministic Second Brain. Like everything else,\nit only uses the provider you chose, under the same gate."},"310":{"id":"/privacy-33","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#local-ai-sees-the-real-thing","content":"When you use a local provider (Ollama, Apple Foundation Models, LM Studio),\nnothing leaves your Mac — so there's no privacy cost to sending the full,\nun-redacted context. Hindsight preserves real names, emails, and phone numbers\nfor local providers so the Second Brain grounds on the real thing instead of\n`[REDACTED:name]` placeholders. Secrets (cards, keys, tokens) are still scrubbed\nfor every provider, local or cloud."},"311":{"id":"/privacy-34","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#every-answer-is-verified","content":"Every chat answer from the Second Brain is checked against your actual captured\nhistory before it's shown. If the model invents a person, project, or fact that\nisn't grounded in your data, the claim is stripped out. This verification runs\non every answer — not just the relational ones — so a fabricated claim can never\nslip through regardless of the question type."},"312":{"id":"/privacy-35","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#where-to-configure-it-the-colophon","content":"All of these settings live in **the Colophon**, Hindsight's settings page. Open\nthe Index with ⌘K and choose **Colophon**, then go to the\n**Intelligence** section."},"313":{"id":"/privacy-36","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#where-to-configure-it-the-colophon","content":"To connect a provider:"},"314":{"id":"/privacy-37","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#where-to-configure-it-the-colophon","content":"Pick a provider from **AI option** (or **None** to disconnect)."},"315":{"id":"/privacy-38","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#where-to-configure-it-the-colophon","content":"For a cloud provider, paste your **API key**. For a local provider, leave the\nkey blank."},"316":{"id":"/privacy-39","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#where-to-configure-it-the-colophon","content":"Optionally set a **base URL** (for OpenAI-compatible endpoints this is\nrequired) and a **model**, or use **Refresh list** to pull available models."},"317":{"id":"/privacy-40","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#where-to-configure-it-the-colophon","content":"Press **Test Connection** to verify, then **Save**."},"318":{"id":"/privacy-41","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#where-to-configure-it-the-colophon","content":"When a cloud provider is selected, the **Allow cloud AI** master toggle appears\nunder **The Second Brain** — one trust decision, with **Share your profile** as\nan optional sub-toggle for sending your name and role. When a local provider is\nselected, the cloud toggles are hidden and you'll see a simple \"Your AI runs on\nyour Mac — nothing leaves this device.\" Under **External Readers** you'll find\nthe agent (MCP) toggles."},"319":{"id":"/privacy-42","page_id":"/privacy","tags":[],"type":"text","url":"/privacy#where-your-keys-are-stored","content":"Your API key is stored only in the **macOS Keychain**, in a per-provider entry\nunder a Hindsight-specific service. It is never written to the app's\npreferences and never appears in your saved configuration. Switching providers\nkeeps each provider's key in the Keychain, so you can move back and forth without\nre-entering it. Pressing **Clear** removes the active provider's key from the\nKeychain."},"320":{"id":"/recall","page_id":"/recall","type":"page","content":"Recall","breadcrumbs":["Hindsight"],"tags":[],"url":"/recall"},"321":{"id":"/recall-0","page_id":"/recall","tags":[],"type":"text","url":"/recall","content":"Ask your book a question and get an answer drawn from your own days and meetings, with a link back to the exact moment it came from."},"322":{"id":"/recall-1","page_id":"/recall","type":"heading","tags":[],"url":"/recall#the-index-jump-anywhere","content":"The Index: jump anywhere"},"323":{"id":"/recall-2","page_id":"/recall","type":"heading","tags":[],"url":"/recall#ask-the-book-a-question-across-every-day","content":"Ask the Book: a question across every day"},"324":{"id":"/recall-3","page_id":"/recall","type":"heading","tags":[],"url":"/recall#how-the-answer-is-built","content":"How the answer is built"},"325":{"id":"/recall-4","page_id":"/recall","type":"heading","tags":[],"url":"/recall#quick-filters","content":"Quick filters"},"326":{"id":"/recall-5","page_id":"/recall","type":"heading","tags":[],"url":"/recall#what-you-keep-coming-back-to","content":"What you keep coming back to"},"327":{"id":"/recall-6","page_id":"/recall","type":"heading","tags":[],"url":"/recall#asking-about-a-single-meeting","content":"Asking about a single meeting"},"328":{"id":"/recall-7","page_id":"/recall","type":"heading","tags":[],"url":"/recall#a-note-on-where-this-runs","content":"A note on where this runs"},"329":{"id":"/recall-8","page_id":"/recall","tags":[],"type":"text","url":"/recall","content":"Recall is how you ask your book a question and get a real answer back — built\nfrom what you actually saw and recorded, not from the open web. Two surfaces\nwork together: the **Index** for jumping straight to a page, and **Ask the\nBook** for questions that span many days at once."},"330":{"id":"/recall-9","page_id":"/recall","tags":[],"type":"text","url":"/recall#the-index-jump-anywhere","content":"Press ⌘K from anywhere to open the Index. It is both a table of\ncontents and a search box for the whole book."},"331":{"id":"/recall-10","page_id":"/recall","tags":[],"type":"text","url":"/recall#the-index-jump-anywhere","content":"Start typing and it filters across everything in one place:"},"332":{"id":"/recall-11","page_id":"/recall","tags":[],"type":"text","url":"/recall#the-index-jump-anywhere","content":"**The Days** — any page in your Day Journal, by title, summary, or date."},"333":{"id":"/recall-12","page_id":"/recall","tags":[],"type":"text","url":"/recall#the-index-jump-anywhere","content":"**Minutes** — a recorded meeting, by title."},"334":{"id":"/recall-13","page_id":"/recall","tags":[],"type":"text","url":"/recall#the-index-jump-anywhere","content":"**Commonplace Book** — beliefs you've kept."},"335":{"id":"/recall-14","page_id":"/recall","tags":[],"type":"text","url":"/recall#the-index-jump-anywhere","content":"**Lexicon** — corrective words and snippets."},"336":{"id":"/recall-15","page_id":"/recall","tags":[],"type":"text","url":"/recall#the-index-jump-anywhere","content":"**Colophon** — any setting, landing on its own row."},"337":{"id":"/recall-16","page_id":"/recall","tags":[],"type":"text","url":"/recall#the-index-jump-anywhere","content":"**Commands** — actions you can run, like Turn to today or Begin minutes."},"338":{"id":"/recall-17","page_id":"/recall","tags":[],"type":"text","url":"/recall#the-index-jump-anywhere","content":"Open with an empty query and the Index shows a table of contents instead: the\nParts of your book, your three most recent days, your three most recent\nminutes, and the common commands."},"339":{"id":"/recall-18","page_id":"/recall","tags":[],"type":"text","url":"/recall#the-index-jump-anywhere","content":"Move the selection with the up and down arrows, press Return to go,\nand Esc to dismiss — focus returns to the page you were on. The\nIndex is fast because it reads from what's already in memory; there's no\nwaiting."},"340":{"id":"/recall-19","page_id":"/recall","tags":[],"type":"text","url":"/recall#ask-the-book-a-question-across-every-day","content":"When you want an answer rather than a destination, ask the book. Open today's\npage and use the &#x2A;*Ask the book…** bar, or press ⇧⌘A from anywhere\nto jump there and start typing."},"341":{"id":"/recall-20","page_id":"/recall","tags":[],"type":"text","url":"/recall#ask-the-book-a-question-across-every-day","content":"The full Ask the Book view searches **anything you saw, across every day**.\nType a question — \"what was the address jane.smith sent me?\", \"which build\nbroke last Thursday?\" — and the book answers from your own captured history."},"342":{"id":"/recall-21","page_id":"/recall","tags":[],"type":"text","url":"/recall#how-the-answer-is-built","content":"If you've connected an AI provider, the answer streams back as prose, written\nonly from the days and frames that match your question. Under the answer is a\n**Sources** list. Each source is the exact frame the answer drew from, shown as\nits time, the app, and the window title — for example:"},"343":{"id":"/recall-22","page_id":"/recall","tags":[],"type":"text","url":"/recall#how-the-answer-is-built","content":"Click any source to open that frame: the original screen, at the moment it was\ncaptured, so you can verify the answer with your own eyes. Every `[#N]` in the\nanswer maps to a row in the list."},"344":{"id":"/recall-23","page_id":"/recall","tags":[],"type":"text","url":"/recall#how-the-answer-is-built","content":"If you haven't connected a provider, Recall still works. Instead of prose, it\nreturns **cards** — each one a specific match (a phone number, an email, a\nlink, a file you saw) carrying the same time-and-place stamp, and a click opens\nthe frame it came from. Recording and search never need a provider; the answer\nstyle just changes."},"345":{"id":"/recall-24","page_id":"/recall","tags":[],"type":"text","url":"/recall#quick-filters","content":"The Ask the Book view offers one-tap chips for the things people look for most:"},"346":{"id":"/recall-25","page_id":"/recall","tags":[],"type":"text","url":"/recall#quick-filters","content":"**Phone numbers**"},"347":{"id":"/recall-26","page_id":"/recall","tags":[],"type":"text","url":"/recall#quick-filters","content":"**Emails**"},"348":{"id":"/recall-27","page_id":"/recall","tags":[],"type":"text","url":"/recall#quick-filters","content":"**Links**"},"349":{"id":"/recall-28","page_id":"/recall","tags":[],"type":"text","url":"/recall#quick-filters","content":"**Files**"},"350":{"id":"/recall-29","page_id":"/recall","tags":[],"type":"text","url":"/recall#quick-filters","content":"Tap one to seed the search and see every matching moment."},"351":{"id":"/recall-30","page_id":"/recall","tags":[],"type":"text","url":"/recall#what-you-keep-coming-back-to","content":"Before you've typed anything, Recall shows **You keep coming back to** — the\npeople, sites, and files that recur across your days, each with how many days\nit spans and how many times you've seen it. Tap one to turn it into a search."},"352":{"id":"/recall-31","page_id":"/recall","tags":[],"type":"text","url":"/recall#asking-about-a-single-meeting","content":"Inside a recorded meeting you can ask about that meeting on its own. Open the\nmeeting and use the &#x2A;*Ask about this meeting…** field to question its\ntranscript and your notes directly, without searching the rest of the book."},"353":{"id":"/recall-32","page_id":"/recall","tags":[],"type":"text","url":"/recall#a-note-on-where-this-runs","content":"Recall reads your own on-device book. Search and the deterministic card results\nstay entirely on your Mac. The streamed prose answer uses whatever AI provider\nyou've connected in the Colophon — and a local provider keeps everything on\nyour Mac for that too."},"354":{"id":"/release-notes","page_id":"/release-notes","type":"page","content":"Release notes","breadcrumbs":["Hindsight"],"tags":[],"url":"/release-notes"},"355":{"id":"/release-notes-0","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes","content":"What changed in each version of Hindsight, newest first."},"356":{"id":"/release-notes-1","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#160","content":"1.6.0"},"357":{"id":"/release-notes-2","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#152","content":"1.5.2"},"358":{"id":"/release-notes-3","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#151","content":"1.5.1"},"359":{"id":"/release-notes-4","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#150","content":"1.5.0"},"360":{"id":"/release-notes-5","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#141","content":"1.4.1"},"361":{"id":"/release-notes-6","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#140","content":"1.4.0"},"362":{"id":"/release-notes-7","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#131","content":"1.3.1"},"363":{"id":"/release-notes-8","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#130","content":"1.3.0"},"364":{"id":"/release-notes-9","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#120","content":"1.2.0"},"365":{"id":"/release-notes-10","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#111","content":"1.1.1"},"366":{"id":"/release-notes-11","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#110","content":"1.1.0"},"367":{"id":"/release-notes-12","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#1012","content":"1.0.12"},"368":{"id":"/release-notes-13","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#1011","content":"1.0.11"},"369":{"id":"/release-notes-14","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#1010","content":"1.0.10"},"370":{"id":"/release-notes-15","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#109","content":"1.0.9"},"371":{"id":"/release-notes-16","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#108","content":"1.0.8"},"372":{"id":"/release-notes-17","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#107","content":"1.0.7"},"373":{"id":"/release-notes-18","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#106","content":"1.0.6"},"374":{"id":"/release-notes-19","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#105","content":"1.0.5"},"375":{"id":"/release-notes-20","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#104","content":"1.0.4"},"376":{"id":"/release-notes-21","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#103","content":"1.0.3"},"377":{"id":"/release-notes-22","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#102","content":"1.0.2"},"378":{"id":"/release-notes-23","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#101","content":"1.0.1"},"379":{"id":"/release-notes-24","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#100","content":"1.0.0"},"380":{"id":"/release-notes-25","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#day-journal","content":"Day Journal"},"381":{"id":"/release-notes-26","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#meetings","content":"Meetings"},"382":{"id":"/release-notes-27","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#second-brain","content":"Second Brain"},"383":{"id":"/release-notes-28","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#on-device-by-default","content":"On-device by default"},"384":{"id":"/release-notes-29","page_id":"/release-notes","type":"heading","tags":[],"url":"/release-notes#requirements","content":"Requirements"},"385":{"id":"/release-notes-30","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes","content":"What's new in Hindsight, newest first. Hindsight keeps itself up to date, and\nyou can check manually from the Colophon under **The Apparatus → Check for\nupdates**."},"386":{"id":"/release-notes-31","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#160","content":"A more AI-driven Second Brain — pick your own embedding model, smarter suggested to-dos, and meaning-aware file indexing — plus a wave of reliability fixes across reminders, your days, and the Second Brain."},"387":{"id":"/release-notes-32","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#160","content":"**Choose your embedding model — and it's used everywhere.** The embedding model you pick for Folder Context RAG now drives *both* indexing and search, so your files and your queries are always embedded with the same model (a mismatch used to silently break semantic search). Point it at a local model in Ollama, LM Studio, or oMLX and nothing leaves your Mac; a cloud embedding model only ever receives your file text if you explicitly choose one and grant consent."},"388":{"id":"/release-notes-33","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#160","content":"**Smarter suggested to-dos.** Today's task suggestions are rephrased into natural, imperative tasks; meeting action items are extracted by the model from the meeting text; and tasks you pull from a specific meeting now stay on the rail when the page refreshes. Each step falls back to the built-in, on-device behavior when no model is connected."},"389":{"id":"/release-notes-34","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#160","content":"**Meaning-aware file chunking.** With a local model configured, files are split into sections by meaning instead of by paragraph or page, so retrieval lands on coherent passages — and it falls back cleanly to structural chunking otherwise. PDFs and spreadsheets keep their page-accurate citations."},"390":{"id":"/release-notes-35","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#160","content":"**File search actually uses your vectors.** Semantic file search now runs whenever you've typed a query (multi-word queries used to silently drop to keyword-only), re-indexes only the files that changed instead of re-embedding the whole folder every time, can be cancelled mid-run, and tells you when a folder has nothing to index."},"391":{"id":"/release-notes-36","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#160","content":"**Reminders that behave.** \"Add to Reminders\" confirms when it worked, won't pile up duplicates, and writes the whole list in one pass — and an imminent meeting's reminder is no longer dropped when notification permission was still warming up."},"392":{"id":"/release-notes-37","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#160","content":"**Faster, more honest day pages.** Opening a day no longer hitches the interface, screenshots use far less memory, the timeline shows the whole day (not just the first stretch of it), per-app time and on-disk storage are reported accurately, and deleting a day takes a single confirmation."},"393":{"id":"/release-notes-38","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#160","content":"**A steadier Second Brain.** Beliefs no longer fade away prematurely, so your self-model and persona stay populated; chat citations resolve to the right frames after you reopen a conversation; and the self-model keeps updating even in Low Power Mode."},"394":{"id":"/release-notes-39","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#160","content":"Requires macOS 14.2 or later, Apple Silicon."},"395":{"id":"/release-notes-40","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#152","content":"Debugging tools for the embeddings provider — so you can tell when your model isn't loaded and fix it without reading server logs."},"396":{"id":"/release-notes-41","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#152","content":"**Test Connection for embeddings.** The embeddings provider card now has a \"Test Connection\" button (just like the chat AI). It sends a tiny embed request to your configured endpoint and tells you whether it worked — including the served model and vector dimensions — or shows the exact error. No more guessing whether your model is loaded or the name is right."},"397":{"id":"/release-notes-42","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#152","content":"**Diagnostic logging.** The embeddings path now logs to Console.app (subsystem `com.iannellomarco.hindsight.core`, category `Embeddings` + `FileIndexer`). You can see exactly what model was requested, whether it succeeded, and when the app fell back to the on-device model — filter Console by the subsystem and send the logs when something's off."},"398":{"id":"/release-notes-43","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#152","content":"Requires macOS 14.2 or later, Apple Silicon."},"399":{"id":"/release-notes-44","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#151","content":"A dedicated embeddings model picker for Folder Context RAG — and three fixes the adversarial code review caught before they reached you."},"400":{"id":"/release-notes-45","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#151","content":"**Pick your embeddings model.** Folder Context RAG now has its own provider config in Settings → Intelligence → File Index, parallel to your chat AI. Point it at Harrier OSS v1 0.6B (or any embedding model) in your Ollama, LM Studio, or oMLX instance — independent of your chat model. A refresh-from-provider list helps you pick. With none set, files use the on-device model."},"401":{"id":"/release-notes-46","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#151","content":"**Saves take effect immediately.** Configuring the embeddings model used to require an app relaunch (a stale-capture bug froze the old config). Now the index and retrieval read the live setting on every call — change the model, hit re-index, and it's used right away."},"402":{"id":"/release-notes-47","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#151","content":"**File content never leaves your Mac.** The fallback path that used your chat AI for embeddings is now gated to local providers only — a cloud chat provider will never receive your file text for embedding."},"403":{"id":"/release-notes-48","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#151","content":"**Retrieval uses the right model.** A matching fix ensures the query vectors and the indexed vectors come from the same model, so semantic search actually works (it was silently mismatched before)."},"404":{"id":"/release-notes-49","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#151","content":"Requires macOS 14.2 or later, Apple Silicon. We recommend Harrier OSS v1 0.6B (the MLX 8-bit build) in your Ollama or LM Studio instance for file embeddings."},"405":{"id":"/release-notes-50","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#150","content":"Your Second Brain now leads with genuine AI insight, reads your own files, and works reliably on local models — all on-device, all private."},"406":{"id":"/release-notes-51","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#150","content":"**The page now leads with what the AI actually did.** The Second Brain used to open with templated counting (\"X sits at the center of a lot of what you do\", cycling a few phrases). Now the AI Reflection — grounded observations written from your real captured moments — leads the page, and the templated belief cards are rephrased into varied, specific observations by the model. The vanity stat row is gone. With no AI connected, you get an honest \"connect a model\" prompt instead of fake templated confidence."},"407":{"id":"/release-notes-52","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#150","content":"**Your Second Brain can now read your files.** Point Hindsight at a workspace folder — a repo, a docs folder, a papers folder — and it indexes everything inside on your Mac: code, markdown, PDFs, images (via OCR), spreadsheets, rich text, email. The Reflection can then connect your screen activity to your own work artifacts, cited by file. \"You switched to Slack right after the compile errors your plan flagged.\" Nothing leaves your Mac; embeddings run on your local model."},"408":{"id":"/release-notes-53","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#150","content":"**Local AI is now reliable enough to be the primary brain.** Hindsight now asks your local model (Ollama, LM Studio, oMLX) for structured JSON output instead of prompting and hoping — the change that makes a 3–8B local model dependable as your main Second Brain, not a fallback. Cloud stays optional and opt-in."},"409":{"id":"/release-notes-54","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#150","content":"**The Reflection checks itself, and sees the right frames.** Every reflection is now verified against your actual captured data before it sticks — a fabricated name paired with a real citation gets stripped. And it retrieves semantically-relevant frames (not just the most recent ones), so a reflection about \"the migration\" pulls migration moments from across the week."},"410":{"id":"/release-notes-55","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#150","content":"Today's Focus is sharper and lands in Reminders:"},"411":{"id":"/release-notes-56","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#150","content":"**Cleaner, more useful todos.** Citation markers and raw URLs/IPs no longer leak into your todo titles, and machine-internal detail text is replaced with human guidance. A tighter, higher-quality list."},"412":{"id":"/release-notes-57","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#150","content":"**Send to Reminders, not Notes.** The export now creates one checkable reminder per todo in a \"Hindsight\" list — native checklist, individually completable, syncs to your iPhone. Action items belong in Reminders."},"413":{"id":"/release-notes-58","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#150","content":"Requires macOS 14.2 or later, Apple Silicon. Folder Context RAG and the local-AI improvements work best with a local embedding model (we recommend Harrier OSS v1 0.6B, the MLX 8-bit build, in your Ollama or LM Studio instance) — but everything degrades gracefully to the on-device model when none is running."},"414":{"id":"/release-notes-59","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#141","content":"Today's Focus is now smarter, always visible, and reachable from every meeting."},"415":{"id":"/release-notes-60","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#141","content":"**Extract Todos from any meeting.** A new checklist button in the meeting detail reads the transcript and pulls out the action items — things you said you'd do, were asked to do, or agreed to. They land in Today's Focus immediately, each tagged with the meeting it came from."},"416":{"id":"/release-notes-61","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#141","content":"**Todos from real content, not just patterns.** When an AI provider is connected, Today's Focus now reads the actual text of your meeting transcripts and on-screen captures — not just the statistics — and extracts specific, actionable tasks (\"Send the brief to Jane by Friday\") instead of pattern inferences (\"You haven't touched plan.md in 8 days\")."},"417":{"id":"/release-notes-62","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#141","content":"**Always-visible, always-refreshable.** The Today's Focus rail is now always on screen — even when empty, it shows what to do to surface tasks. A refresh button lets you regenerate on demand."},"418":{"id":"/release-notes-63","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#141","content":"**Auto-extract after meetings.** When a meeting finishes, its action items are extracted automatically — you don't have to do anything."},"419":{"id":"/release-notes-64","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#141","content":"Requires macOS 14.2 or later, Apple Silicon."},"420":{"id":"/release-notes-65","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#140","content":"Your Second Brain now genuinely thinks about your work — and the whole app got sharper, more honest, and more consistent."},"421":{"id":"/release-notes-66","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#140","content":"**The Reflection.** After you finish a day (or when you open Hindsight in the morning), your Second Brain reads the actual moments it captured — not just the counts, but what was on your screen, in what order, at what time — and writes a short Reflection: two or three genuine observations a thoughtful colleague might make. Every claim points back to the specific moments it noticed it in. It runs on your Mac if you use Apple Foundation Models or Ollama — free, private, no cloud needed."},"422":{"id":"/release-notes-67","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#140","content":"**A self-model that develops over time.** The Reflection's observations now become lasting beliefs. When the same pattern recurs across days, it firms up; when it doesn't, it fades. Recurring patterns promote to stable traits, and those traits shape what the Second Brain notices next — so its understanding deepens, not just accumulates."},"423":{"id":"/release-notes-68","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#140","content":"**The story of becoming.** The \"Who you are\" card on the You tab now tells a narrative — what the Second Brain has come to understand about you, how that's changed recently, and where it sees tension."},"424":{"id":"/release-notes-69","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#140","content":"**Today's Focus.** A new panel on Today surfaces suggested to-dos from your patterns — files you opened then dropped, topics that faded, action items from meetings. Check one off, dismiss it, or send the whole list to Apple Notes with one click."},"425":{"id":"/release-notes-70","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#140","content":"**Hide your voice from transcripts.** A one-click \"Hide my voice\" toggle on any meeting transcript. Your turns disappear from the view, but nothing is destroyed — bring them back anytime. It survives re-analysis too."},"426":{"id":"/release-notes-71","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#140","content":"Trust and privacy hardening:"},"427":{"id":"/release-notes-72","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#140","content":"**Every answer is now verified.** The Second Brain's honesty guard — which strips any claim it can't ground in your actual captured data — now runs on every chat answer, not just the relational ones."},"428":{"id":"/release-notes-73","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#140","content":"**Settings you can trust.** Three toggles that promised behavior but never actually did anything have been fixed or removed. The cloud-consent controls are now one clear decision instead of three cross-referencing toggles."},"429":{"id":"/release-notes-74","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#140","content":"Plus: the Apple Notes Automation entitlement for one-click todo export, LLM-assisted phrasing of suggested to-dos when a provider is connected, meeting action items flowing into the Today's Focus rail, and dozens of accessibility improvements."},"430":{"id":"/release-notes-75","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#140","content":"Requires macOS 14.2 or later, Apple Silicon."},"431":{"id":"/release-notes-76","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#131","content":"A smarter privacy boundary for on-device AI — and a more consistent feel throughout."},"432":{"id":"/release-notes-77","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#131","content":"**Local AI now grounds on the real thing.** When you use an on-device provider (Ollama, Apple Foundation Models, or LM Studio), Hindsight no longer strips contact details from what the model sees — names, emails, and phone numbers are preserved so your Second Brain and chat answers reference real people and projects instead of `[REDACTED:name]`. Nothing leaves your Mac, so there's no privacy cost. Secrets (cards, keys, tokens) are still scrubbed for every provider."},"433":{"id":"/release-notes-78","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#131","content":"**Meeting chat speaks up when it fails.** A question to a meeting that can't reach the AI provider now shows the reason inline, instead of going silent or leaving a placeholder message behind."},"434":{"id":"/release-notes-79","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#131","content":"**One Send, everywhere.** The ask boxes in the meeting panel, meeting detail, and journal chats now share the same look and the same Send control — a consistent composer across the whole app."},"435":{"id":"/release-notes-80","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#131","content":"**Keyboard tabs in meetings.** Switch a meeting's Transcript / Results / Chat / Speakers with `⌘1`–`⌘4`, matching the rest of the app."},"436":{"id":"/release-notes-81","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#131","content":"Plus the usual polish: standardized section headings and spacing, a centered empty state on Meetings, and sharper accessibility labels."},"437":{"id":"/release-notes-82","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#130","content":"Find any day in your history at a glance, and never lose one to an accidental delete."},"438":{"id":"/release-notes-83","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#130","content":"**The Day Index.** Press `⌘L` anywhere to open a chronological overview of every captured day — title, date, and a thumbnail for each, with a density strip showing how much history you've built. Use `↑↓` to move and `Return` to turn straight to a day."},"439":{"id":"/release-notes-84","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#130","content":"**Recoverable deletions.** Deleting a day now removes it from the book but offers an *Undo* right after, from Today — so a mistake never costs you a captured day."},"440":{"id":"/release-notes-85","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#130","content":"**Always-on sidebar.** The book's Parts are visible by default on launch; unpin from the masthead toggle if you'd rather have the room."},"441":{"id":"/release-notes-86","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#130","content":"**Richer timeline.** Every activity row now shows a thumbnail you can click to open full-size — not just the starred moments."},"442":{"id":"/release-notes-87","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#130","content":"A real privacy hardening for AI vision:"},"443":{"id":"/release-notes-88","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#130","content":"**Secret-bearing frames never leave your Mac.** If a screenshot's captured text revealed a card, key, or token, its pixels are no longer sent to a vision provider — the text redactor can't see into the image, so the whole frame is withheld."},"444":{"id":"/release-notes-89","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#130","content":"**Honest about what vision sees.** The vision setting and the on-day redaction badge now say plainly: captured text is scrubbed, but visible pixels sent for descriptions are not."},"445":{"id":"/release-notes-90","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#130","content":"And a sweep of reliability and polish: the recording control no longer lets *Discard* look like the main action; a failed Second Brain question now tells you instead of hanging; the \"relaunch to apply Screen Recording\" state stays visible until you act on it; a new multi-step progress bar in setup; and consistent ask fields, status dots, and delete confirmations throughout."},"446":{"id":"/release-notes-91","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#120","content":"The Second Brain now answers from what your screens actually showed — not just who and\nwhat kept recurring."},"447":{"id":"/release-notes-92","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#120","content":"**Answers from real content.** Ask \"why do I keep working with this client?\" and the chat reads\nthe actual text of the relevant moments — emails, docs, messages — and grounds its answer\nin them, with citations you can click to jump straight to the frame."},"448":{"id":"/release-notes-93","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#120","content":"**It knows you're not your own coworker.** The Second Brain no longer lists you among the\npeople you work with."},"449":{"id":"/release-notes-94","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#120","content":"**Tighter privacy at the edge.** When a cloud model is in use, email addresses and phone\nnumbers are scrubbed from what's sent — on top of the existing secret redaction."},"450":{"id":"/release-notes-95","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#120","content":"The Days page is also redesigned:"},"451":{"id":"/release-notes-96","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#120","content":"**A sidebar for the book.** An always-available table of contents. It auto-hides to give\nthe page room — hover the left edge to peek it open — or pin it from the toggle in the top-left."},"452":{"id":"/release-notes-97","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#120","content":"**Timeline previews.** Each moment in a day's timeline now shows a thumbnail you can click\nto open full-size."},"453":{"id":"/release-notes-98","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#120","content":"A bigger delete control, and clearer labels distinguishing asking the whole book from\nchatting with a single day."},"454":{"id":"/release-notes-99","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#111","content":"Two fixes to the Second Brain."},"455":{"id":"/release-notes-100","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#111","content":"**Dismiss sticks.** When you dismiss something the Second Brain inferred about you, it\nno longer quietly comes back the next day."},"456":{"id":"/release-notes-101","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#111","content":"**Sharper recall.** Asking about a specific person or file now surfaces the right ones\nto jump to, instead of coming up empty on a normally-worded question."},"457":{"id":"/release-notes-102","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#110","content":"Your Second Brain now understands *you* — not just the people, files, and projects in\nyour work, but who you are and how your days have been going."},"458":{"id":"/release-notes-103","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#110","content":"**It knows you.** Tell it your name and role (during setup, or anytime in Settings) and\nit speaks to you personally — greeting you by name and writing your day as someone it\nactually knows."},"459":{"id":"/release-notes-104","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#110","content":"**It learns you.** From your own days it quietly works out things like your role, the\nway you work, and how you've been feeling — and asks you to confirm the important guesses\nbefore trusting them. Nothing is assumed, and anything that feels off is one tap to dismiss."},"460":{"id":"/release-notes-105","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#110","content":"**A new \"You\" tab.** A home for your profile: a short portrait of who you are, the traits\nit has noticed, and a timeline of how your days have felt."},"461":{"id":"/release-notes-106","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#110","content":"**Private by default.** All of this stays on your Mac and works with on-device AI. Sharing\nyour profile with a cloud provider takes a separate, explicit opt-in."},"462":{"id":"/release-notes-107","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#1012","content":"A broad polish pass: more reliable meeting status, far wider accessibility, and a\nfaster, more consistent interface."},"463":{"id":"/release-notes-108","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#1012","content":"**Meeting status updates instantly.** The menu-bar recording glyph, the permission\nprompt when a recording is blocked, and the \"transcribing…\" indicator now reflect\nwhat's happening the moment it changes."},"464":{"id":"/release-notes-109","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#1012","content":"**Much better VoiceOver support.** Buttons and controls across the app — Meetings,\nthe Day Journal, the Second Brain, onboarding, and the Index — now announce\nmeaningful names, and secondary text meets WCAG AA contrast."},"465":{"id":"/release-notes-110","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#1012","content":"**Snappier reading.** Opening a finished day, searching the Index, and reading\nstreamed answers are all faster and smoother."},"466":{"id":"/release-notes-111","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#1012","content":"**Clearer meetings.** The section is consistently called \"Meetings\", larger calls\nget more distinct speaker colors, the connect-calendar prompt refreshes after you\ngrant access, and a failed prompt now shows an error instead of doing nothing."},"467":{"id":"/release-notes-112","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#1012","content":"**Rebindable meeting hotkey.** The global start/stop shortcut (default ⌘⇧M) can now\nbe changed in Settings → The Minutes."},"468":{"id":"/release-notes-113","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#1012","content":"**Smaller fixes.** Onboarding scrolls on small displays, the meeting audio player\nresets at the end of a clip, deleting a custom word asks first, and a failed app\nsummary can be retried."},"469":{"id":"/release-notes-114","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#1011","content":"A fix so a finished day always shows up where you expect it."},"470":{"id":"/release-notes-115","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#1011","content":"**New days appear right away.** After you stop and save a day, it now shows up\non the Days page immediately — previously a freshly finished day could stay\nhidden there until you quit and reopened the app."},"471":{"id":"/release-notes-116","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#1010","content":"Much better speaker detection, plus new ways to fix up a meeting after it's\nrecorded."},"472":{"id":"/release-notes-117","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#1010","content":"**Far better speaker separation.** A one-on-one call is no longer split into a\nhandful of phantom speakers, and genuine group meetings keep everyone — the\nspeaker count is no longer capped, so a large call isn't truncated down to a\nfew voices."},"473":{"id":"/release-notes-118","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#1010","content":"**Re-analyze a meeting.** A new button on a saved meeting re-runs transcription\nand speaker detection on the original audio — so you can pick up these speaker\nimprovements on meetings recorded earlier, without recording again."},"474":{"id":"/release-notes-119","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#1010","content":"**Rename a meeting.** A pencil next to the title renames a meeting at any time."},"475":{"id":"/release-notes-120","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#1010","content":"**Name a meeting from your calendar.** One click names a meeting after the\ncalendar event it overlaps, so your recordings match your schedule."},"476":{"id":"/release-notes-121","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#1010","content":"**Refreshed meeting tabs.** The Transcript / Results / Chat / Speakers tabs now\nuse the same thumb-tab style as the rest of the app."},"477":{"id":"/release-notes-122","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#109","content":"A formatting hotfix for AI answers."},"478":{"id":"/release-notes-123","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#109","content":"**AI answers are now formatted.** Responses from Ask, the Second Brain, and\nmeeting Q\\&A render their Markdown — bold, italic, headings, and bullet lists —\ninstead of showing raw \"\\*\\*\" and \"\\*\" characters."},"479":{"id":"/release-notes-124","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#108","content":"Fixes meeting transcription."},"480":{"id":"/release-notes-125","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#108","content":"**Transcription no longer freezes.** A scheduling deadlock could leave the live\ntranscript blank during a meeting and the post-recording \"transcribing…\" step\nstuck indefinitely. Recording and transcription now run on separate lanes — the\nlive transcript fills in during the meeting and the final transcript completes\npromptly."},"481":{"id":"/release-notes-126","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#108","content":"**More accurate speakers.** Tightened speaker separation so a single remote\nparticipant is no longer occasionally split into two, and a slow\nspeaker-detection step no longer holds up the final transcript."},"482":{"id":"/release-notes-127","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#107","content":"Clearer day navigation."},"483":{"id":"/release-notes-128","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#107","content":"**Visible page controls.** The Days page now has previous / next buttons and a\ndotted day indicator beneath it — one dot per day, with the current day\nhighlighted. Click any dot to jump straight to that day. (The page-turn\ncontrols were previously invisible edge zones.)"},"484":{"id":"/release-notes-129","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#106","content":"Turning the pages — fixed, and nicer."},"485":{"id":"/release-notes-130","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#106","content":"**Day navigation works again.** The left/right arrow keys (and ⌘\\[ / ⌘]) turn\nbetween days without having to click the page first, and the optional\ntwo-finger swipe (Colophon → \"Turn pages with a two-finger swipe\") is reliable."},"486":{"id":"/release-notes-131","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#106","content":"**A page-peel turn.** Days now turn with a subtle page-peel animation instead\nof a flat slide. Honors Reduce Motion."},"487":{"id":"/release-notes-132","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#106","content":"**New app icon.** A Daybook cover with the rubric-red ribbon bookmark."},"488":{"id":"/release-notes-133","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#105","content":"Meeting recording now starts instantly."},"489":{"id":"/release-notes-134","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#105","content":"**No more waiting to record.** Previously, starting a meeting could pause on\n\"Preparing speech model…\" while the on-device model loaded. Now recording\nbegins immediately and captures audio from the first second; the speech model\nloads in the background."},"490":{"id":"/release-notes-135","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#105","content":"**Visible transcription progress.** While the model loads, the transcript area\nshows a progress bar instead of a frozen screen, and the transcript fills in as\nsoon as the model is ready. The full meeting is always transcribed when you\nstop."},"491":{"id":"/release-notes-136","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#104","content":"A reliability release for meeting recording — especially your first one after\ninstalling."},"492":{"id":"/release-notes-137","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#104","content":"**Meetings wait for the speech model.** If you start recording before the\non-device speech model has finished its one-time setup, Hindsight now shows\n\"Preparing speech model…\" and begins once it's ready, instead of recording a\nmeeting that comes back with an empty transcript."},"493":{"id":"/release-notes-138","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#104","content":"**A more responsive Mac while recording.** Day Journal capture pauses for the\nduration of a meeting, so screen capture and live transcription no longer\ncompete for the Neural Engine — and it resumes automatically when the meeting\nends."},"494":{"id":"/release-notes-139","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#103","content":"A small reliability release for first-run setup."},"495":{"id":"/release-notes-140","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#103","content":"**Clearer Screen Recording setup.** When Hindsight is opened from outside your\nApplications folder — where macOS runs it from a temporary, locked-down copy —\nsetup now tells you to move Hindsight to Applications and reopen it, which is\nthe only way the Screen Recording permission will stick. Previously it pointed\nyou at the \"+\" button, which can't take effect in that case."},"496":{"id":"/release-notes-141","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#103","content":"**Sturdier packaging.** The disk image is now signed unambiguously, and the\ndiagnostics behind the Screen Recording grant were tightened so first-run\nsetup issues are easier to trace."},"497":{"id":"/release-notes-142","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#103","content":"No feature changes — everything in 1.0.0 below is unchanged."},"498":{"id":"/release-notes-143","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#102","content":"**Fixed a launch crash on some Macs.** The bundled Daybook fonts failed to\nload on Macs other than the one the app was built on, which could crash\nHindsight at startup. Fonts now load reliably on every Mac."},"499":{"id":"/release-notes-144","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#102","content":"**Smoother Screen Recording grant.** After you allow Screen Recording, setup\nnow shows a clear **Relaunch Hindsight** step — macOS only applies this\npermission to a freshly launched app, so the relaunch is what makes the grant\ntake effect."},"500":{"id":"/release-notes-145","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#101","content":"A packaging release focused on a smoother, more reliable first launch."},"501":{"id":"/release-notes-146","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#101","content":"**Notarized and stapled.** The app is signed, notarized by Apple, and the\nnotarization ticket is stapled into the build. macOS can verify Hindsight\noffline, so the first launch is clean even without a network connection — no\nspurious \"damaged\" or \"cannot be opened\" warnings."},"502":{"id":"/release-notes-147","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#101","content":"**Steadier installs.** Hardened the DMG so dragging Hindsight to Applications\nand opening it the first time just works."},"503":{"id":"/release-notes-148","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#101","content":"No feature changes — everything in 1.0.0 below is unchanged."},"504":{"id":"/release-notes-149","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#100","content":"The first release of Hindsight: a private, on-device daybook for macOS. One\ncontinuous book you turn through page by page, with three pillars and an Index\n(⌘K) that jumps anywhere."},"505":{"id":"/release-notes-150","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#day-journal","content":"A running record of your day, woven from periodic screen capture read with\non-device OCR (Apple Vision). Turn between days with the left and right arrows,\nlet the red Ribbon bring you back to today, and use **Ask the book** on any page\nto pose a question about your day or your history. Screenshots and the journal\ndatabase never leave your Mac."},"506":{"id":"/release-notes-151","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#meetings","content":"Record and transcribe meetings on-device. Start one from the Record tile, the\nmenu bar, the Index (**Begin minutes**), or the ⇧⌘M hotkey. Hindsight\ncan watch your calendar and offer to begin a recording when a meeting starts,\nrecognizing Google Meet, Zoom, and Microsoft Teams links."},"507":{"id":"/release-notes-152","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#meetings","content":"Records your **microphone** and your Mac's **system audio** as separate,\ntime-aligned tracks (the default; **System Audio Only** is also available)."},"508":{"id":"/release-notes-153","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#meetings","content":"A floating pill and a live panel with **Notes**, a speaker-labeled\n**Transcript**, and an **Ask** tab."},"509":{"id":"/release-notes-154","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#meetings","content":"Saved meetings keep their transcript, notes, and any Ask conversation, and can\nbe renamed and re-run through prompt templates."},"510":{"id":"/release-notes-155","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#second-brain","content":"A page that reads across every day you've captured, links the things that keep\nrecurring, and forms plain-language **beliefs** about your focus. It moves\nbetween **Chat**, **Insights**, **Network**, and **Export**. The beliefs,\nInsights, and Network are computed locally and work with no AI provider\nconnected; recall grounds every chat answer in your real history with citations\nback to the moment each claim came from."},"511":{"id":"/release-notes-156","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#on-device-by-default","content":"**Capture, transcription, and storage stay local.** Meetings are transcribed\non your Mac with the on-device speech model (Parakeet, which runs on the Neural\nEngine), and your journal database never leaves it."},"512":{"id":"/release-notes-157","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#on-device-by-default","content":"**No AI traffic without a provider you choose.** Until you connect an AI\nprovider, nothing is sent anywhere — Ask the book and the Second Brain simply\nwait."},"513":{"id":"/release-notes-158","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#on-device-by-default","content":"**A local provider keeps everything on your machine.** Connect Ollama or\nLM Studio and your text is processed locally."},"514":{"id":"/release-notes-159","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#on-device-by-default","content":"**Cloud is opt-in.** Sending anything to a cloud provider is off until you\nturn it on, and the same gate applies uniformly to journal text, meeting\ntranscripts, chat, and drafts."},"515":{"id":"/release-notes-160","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#requirements","content":"macOS 14.2 or later."},"516":{"id":"/release-notes-161","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#requirements","content":"Apple Silicon (M-series) — the on-device speech model runs on the Neural\nEngine."},"517":{"id":"/release-notes-162","page_id":"/release-notes","tags":[],"type":"text","url":"/release-notes#requirements","content":"A few gigabytes of free disk space for the speech model, which downloads once\nduring first-time setup."},"518":{"id":"/second-brain","page_id":"/second-brain","type":"page","content":"Second Brain","breadcrumbs":["Hindsight"],"tags":[],"url":"/second-brain"},"519":{"id":"/second-brain-0","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain","content":"Your cross-day knowledge graph — the people, projects, and files you keep returning to, the beliefs Hindsight forms about your focus, and how recall draws on them."},"520":{"id":"/second-brain-1","page_id":"/second-brain","type":"heading","tags":[],"url":"/second-brain#getting-to-know-you","content":"Getting to know you"},"521":{"id":"/second-brain-2","page_id":"/second-brain","type":"heading","tags":[],"url":"/second-brain#the-knowledge-graph","content":"The knowledge graph"},"522":{"id":"/second-brain-3","page_id":"/second-brain","type":"heading","tags":[],"url":"/second-brain#beliefs-about-your-focus","content":"Beliefs about your focus"},"523":{"id":"/second-brain-4","page_id":"/second-brain","type":"heading","tags":[],"url":"/second-brain#the-reflection","content":"The Reflection"},"524":{"id":"/second-brain-5","page_id":"/second-brain","type":"heading","tags":[],"url":"/second-brain#how-the-self-model-develops","content":"How the self-model develops"},"525":{"id":"/second-brain-6","page_id":"/second-brain","type":"heading","tags":[],"url":"/second-brain#the-story-of-becoming","content":"The story of becoming"},"526":{"id":"/second-brain-7","page_id":"/second-brain","type":"heading","tags":[],"url":"/second-brain#insights","content":"Insights"},"527":{"id":"/second-brain-8","page_id":"/second-brain","type":"heading","tags":[],"url":"/second-brain#network","content":"Network"},"528":{"id":"/second-brain-9","page_id":"/second-brain","type":"heading","tags":[],"url":"/second-brain#chat-and-recall","content":"Chat and recall"},"529":{"id":"/second-brain-10","page_id":"/second-brain","type":"heading","tags":[],"url":"/second-brain#export","content":"Export"},"530":{"id":"/second-brain-11","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain","content":"The Second Brain is the Commonplace Book in Hindsight: the page that reflects\nyour own work back to you. It reads across every day you've captured, links the\nthings that keep recurring, and forms a small set of plain-language beliefs about\nwhat you focus on. You can read those beliefs directly, explore how everything\nconnects, and talk through your history."},"531":{"id":"/second-brain-12","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain","content":"Open it from the Index (⌘K) and move between its four sections with\nthe tab bar or ⌘1–⌘4: **Chat**, **Insights**, **Network**,\nand **Export**."},"532":{"id":"/second-brain-13","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#getting-to-know-you","content":"The Second Brain only starts answering once it has seen enough of your work to be\nuseful rather than confidently wrong. The page shows where it stands — **Still\nlearning you**, **Getting to know you**, or **Ready** — with a progress bar and\nfour counts: days, frames, things, and threads."},"533":{"id":"/second-brain-14","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#getting-to-know-you","content":"It turns **Ready** once all four signals are met:"},"534":{"id":"/second-brain-15","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#getting-to-know-you","content":"**5 days** captured"},"535":{"id":"/second-brain-16","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#getting-to-know-you","content":"**300 frames** captured"},"536":{"id":"/second-brain-17","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#getting-to-know-you","content":"**60 distinct things** seen (people, files, sites, and so on)"},"537":{"id":"/second-brain-18","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#getting-to-know-you","content":"**3 recurring threads** — things that show up across more than one day"},"538":{"id":"/second-brain-19","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#getting-to-know-you","content":"Readiness is the weakest of the four, so a lopsided history (many frames but a\nsingle day) keeps warming until it fills out. Keep journaling and it gets there."},"539":{"id":"/second-brain-20","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#the-knowledge-graph","content":"As you work, Hindsight reads the captured text on each page and pulls out the\nconcrete, recall-worthy things in it:"},"540":{"id":"/second-brain-21","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#the-knowledge-graph","content":"**People** — email addresses, and recurring phone numbers"},"541":{"id":"/second-brain-22","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#the-knowledge-graph","content":"**Files** — file paths and named files (matched against an extension list, so\n`roadmap.swift` is recognized but `v1.2` is not)"},"542":{"id":"/second-brain-23","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#the-knowledge-graph","content":"**Sites** — web addresses, kept specific (`github.com/example/widgets` is its\nown thing, not collapsed into a bare `github.com`)"},"543":{"id":"/second-brain-24","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#the-knowledge-graph","content":"**Projects and tickets** — issue references like `#318`"},"544":{"id":"/second-brain-25","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#the-knowledge-graph","content":"**Topics** — recurring subjects that tie the above together"},"545":{"id":"/second-brain-26","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#the-knowledge-graph","content":"Each thing is tied back to the exact moment it appeared and timestamped, so it\ncan be ranked and shown without losing where it came from. Extraction runs\nentirely on your Mac on text that has already been redacted, so secrets such as\ncard numbers, keys, and one-time codes are never turned into entities. Ubiquitous\nplumbing — sign-in portals, analytics, CDNs, and boilerplate files like\n`README.md` or `package-lock.json` — is filtered out so it never looks like a hub\nof your work."},"546":{"id":"/second-brain-27","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#the-knowledge-graph","content":"When two things keep appearing together, that co-occurrence becomes a link. The\nresult is a cross-day graph of who and what your work threads through."},"547":{"id":"/second-brain-28","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#beliefs-about-your-focus","content":"From that graph, Hindsight distills a self-model: a set of one-line **beliefs**\nabout you, each grouped by kind — people you keep dealing with, projects and\nareas of your work, topics that recur, tools and sites you live in, files you\nkeep returning to, rhythms in how you work, and open loops you touched then\ndropped."},"548":{"id":"/second-brain-29","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#beliefs-about-your-focus","content":"Beliefs are derived directly from your history, not guessed by an AI, and every\none carries an honest confidence marker. A belief with thin evidence reads as\n&#x2A;*(tentative)*&#x2A; or &#x2A;*(likely)**; as the same person or file recurs across more\ndays, the belief is reinforced and its confidence grows. The strongest beliefs\nrise to the top of the Commonplace Book."},"549":{"id":"/second-brain-30","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#beliefs-about-your-focus","content":"A few things keep the picture stable and honest:"},"550":{"id":"/second-brain-31","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#beliefs-about-your-focus","content":"A belief needs to show up across **at least two days** before it forms."},"551":{"id":"/second-brain-32","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#beliefs-about-your-focus","content":"Confidence only firms up once enough evidence has accumulated, and a belief\nthat earned trust keeps it."},"552":{"id":"/second-brain-33","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#beliefs-about-your-focus","content":"A single quiet day can't retire a belief — it fades only after several quiet\ndays in a row."},"553":{"id":"/second-brain-34","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#beliefs-about-your-focus","content":"A file or ticket you touched a couple of times and then dropped about a week\nago is flagged as an **open loop**, phrased as a possibility rather than a\nfact."},"554":{"id":"/second-brain-35","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#beliefs-about-your-focus","content":"You can read all of this with no AI provider connected — the beliefs are\ncomputed locally and shown as cards."},"555":{"id":"/second-brain-36","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#the-reflection","content":"When you connect an AI provider, the Second Brain gains a deeper layer: **the\nReflection**. After you finish a day — or when you open Hindsight in the morning\n— it reads the actual moments it captured (not just the counts, but *what was on\nyour screen, in what order, at what time*) and writes a short Reflection: two or\nthree genuine observations a thoughtful colleague might make."},"556":{"id":"/second-brain-37","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#the-reflection","content":"Not \"X is heating up.\" More like: &#x2A;\"You seem to hit a wall around 3pm — switching\nto email right after compile errors.\"* Every observation points back to the\nspecific moments it noticed it in — if it can't ground an observation in\nsomething it actually saw, it doesn't say it."},"557":{"id":"/second-brain-38","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#the-reflection","content":"The Reflection runs on your Mac if you use Apple Foundation Models or Ollama —\nfree, private, no cloud needed. It appears as the lead card in Insights."},"558":{"id":"/second-brain-39","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#the-reflection","content":"The Reflection needs an AI provider. The beliefs, Insights cards, and Network\nwork without one. A local provider (Ollama, Apple Foundation Models) keeps the\nReflection on your Mac."},"559":{"id":"/second-brain-40","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#how-the-self-model-develops","content":"The Reflection's observations don't just appear and vanish — they become lasting\nbeliefs. When the same pattern recurs across days, the observation is reinforced\nand its confidence grows. When it doesn't recur, it fades. Patterns that recur\nenough times promote to stable **traits** — durable dispositions like \"you work\nbest in long morning blocks\" or \"you avoid documentation until pressure builds.\""},"560":{"id":"/second-brain-41","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#how-the-self-model-develops","content":"Those traits then shape what the Second Brain notices next. Its perception is\nconditioned on what it already understands: if it has learned you're a methodical\ndebugger, it pays attention when you break that pattern — and the breakage is\noften the most interesting signal. A higher-order reflection pass periodically\nreads the accumulated beliefs and synthesizes higher-level themes (\"your\navoidance of docs and tests both point to deferring unglamorous work\") and\ntensions (patterns that pull in different directions)."},"561":{"id":"/second-brain-42","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#how-the-self-model-develops","content":"This is the closed loop: observe → believe → reinforce or revise → perceive\ndifferently → observe again. The understanding deepens, not just accumulates.\nAnd it's honest at every step: observations are grounded in real captured\nmoments, every chat answer is verified against the evidence, and beliefs that\ndon't hold up decay and retire."},"562":{"id":"/second-brain-43","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#the-story-of-becoming","content":"The &#x2A;*\"Who you are\"** card on the You tab synthesizes the self-model into a\nnarrative — not a label, but a story of how the Second Brain's understanding of\nyou is developing. It describes what it's come to understand, how that's changed\nrecently, and where it sees tension:"},"563":{"id":"/second-brain-44","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#the-story-of-becoming","content":"> *You're a builder who values deep focus — you work best in long morning blocks,\n> and you've gotten steadier at holding that focus through the afternoon. There's\n> a tension, though: when you hit a compile error, you tend to switch to email —\n> I first noticed this three reflections ago, and it's held.*"},"564":{"id":"/second-brain-45","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#the-story-of-becoming","content":"The narrative is grounded in the accumulated evidence, and it distinguishes\nwhat's firm (stable traits) from what's still emerging (new patterns). It\nupdates as the self-model develops — so it tells a story of becoming, not a\nstatic portrait."},"565":{"id":"/second-brain-46","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#insights","content":"The **Insights** tab surfaces what's worth your attention right now:"},"566":{"id":"/second-brain-47","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#insights","content":"**Reflection** (when an AI provider is connected) — the lead card, with two or\nthree genuine observations grounded in your recent captured moments."},"567":{"id":"/second-brain-48","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#insights","content":"**Worth noticing** — patterns rising or cooling across your recent days, all\nderived deterministically from your history. Each has a quick action to draft\nan email or a follow-up calendar event from it."},"568":{"id":"/second-brain-49","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#insights","content":"**Worth confronting** — a frank, grounded mirror of things your own history\nsuggests, each shown with its evidence. This stays silent unless your tone dial\n(in the Colophon) allows it, and it never fabricates a criticism."},"569":{"id":"/second-brain-50","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#insights","content":"**How your picture has changed** — the arc of how the Second Brain's\nunderstanding of you has shifted over time."},"570":{"id":"/second-brain-51","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#network","content":"The **Network** tab is the graph at a glance:"},"571":{"id":"/second-brain-52","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#network","content":"**Most connected** — the hubs your work threads through."},"572":{"id":"/second-brain-53","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#network","content":"**Surprising connections** — strong links between things that aren't both\ncentral, ranked by how many times more often than chance they appear together."},"573":{"id":"/second-brain-54","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#network","content":"**Areas** — clusters Hindsight detected in the graph."},"574":{"id":"/second-brain-55","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#network","content":"**Your graph** — an interactive node-and-link canvas you can open with **Show\ngraph**."},"575":{"id":"/second-brain-56","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#network","content":"The tab also offers a few starter questions; tapping one drops you into Chat with\nthat question already asked."},"576":{"id":"/second-brain-57","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#chat-and-recall","content":"Chat is the conversational home of the Second Brain. Ask it about your work — who\nyou keep dealing with, the files and tools you live in, or where your time\nactually goes — and it answers from what it has captured."},"577":{"id":"/second-brain-58","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#chat-and-recall","content":"Under the hood, recall grounds every answer in your real history rather than\ninventing anything:"},"578":{"id":"/second-brain-59","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#chat-and-recall","content":"It reads your question for what you're after (a phone number, a file, a site)\nand pulls the matching things from your journal."},"579":{"id":"/second-brain-60","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#chat-and-recall","content":"For relational or temporal questions (\"how are X and Y connected?\", \"what have\nI been doing around Z?\"), it assembles real evidence from the graph and answers\nfrom that bundle, keeping `[#n]` citations so you can jump to the exact moment\neach claim came from."},"580":{"id":"/second-brain-61","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#chat-and-recall","content":"Replies are checked against that evidence before they're saved, so a claim the\nhistory doesn't support is stripped out. This verification runs on **every**\nanswer — not just the relational ones — so a fabricated person or project can\nnever slip through."},"581":{"id":"/second-brain-62","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#chat-and-recall","content":"Conversations are remembered: the Second Brain resumes your thread, keeps a\nrolling summary so long chats stay coherent, and can open a fresh chat when you\nwant one."},"582":{"id":"/second-brain-63","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#chat-and-recall","content":"There's also an **Explain** field for two specific things — enter a person, file,\nor site on each side and Hindsight shows the shared bridges between them, drawn\nonly from your graph."},"583":{"id":"/second-brain-64","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#chat-and-recall","content":"Chat, the Explain field, and drafting use an AI provider; the beliefs,\nInsights, and Network are computed locally and work without one. Connect a\nprovider under **Settings → AI Provider** — a local provider (Ollama, LM\nStudio) keeps everything on your Mac."},"584":{"id":"/second-brain-65","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#export","content":"Everything stays on this Mac, and Export only materializes what you've already\ncaptured:"},"585":{"id":"/second-brain-66","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#export","content":"**Export Obsidian vault** — daily notes with backlinked people, sites, and\nfiles."},"586":{"id":"/second-brain-67","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#export","content":"**Export graph** — your knowledge graph as GraphML (for yEd, Gephi, Obsidian)\nand Mermaid (for Markdown)."},"587":{"id":"/second-brain-68","page_id":"/second-brain","tags":[],"type":"text","url":"/second-brain#export","content":"Both write to your Mac and can be revealed in Finder; nothing leaves your\nmachine."},"588":{"id":"/updates","page_id":"/updates","type":"page","content":"Updates & Support","breadcrumbs":["Hindsight"],"tags":[],"url":"/updates"},"589":{"id":"/updates-0","page_id":"/updates","tags":[],"type":"text","url":"/updates","content":"How Hindsight keeps itself up to date, how to check manually, and where to report problems."},"590":{"id":"/updates-1","page_id":"/updates","type":"heading","tags":[],"url":"/updates#automatic-updates","content":"Automatic updates"},"591":{"id":"/updates-2","page_id":"/updates","type":"heading","tags":[],"url":"/updates#checking-manually","content":"Checking manually"},"592":{"id":"/updates-3","page_id":"/updates","type":"heading","tags":[],"url":"/updates#updates-and-your-meetings","content":"Updates and your meetings"},"593":{"id":"/updates-4","page_id":"/updates","type":"heading","tags":[],"url":"/updates#support-and-feedback","content":"Support and feedback"},"594":{"id":"/updates-5","page_id":"/updates","tags":[],"type":"text","url":"/updates","content":"Hindsight updates itself. New versions download and install in the background, so\nyou generally do not need to do anything to stay current."},"595":{"id":"/updates-6","page_id":"/updates","tags":[],"type":"text","url":"/updates#automatic-updates","content":"Hindsight checks for updates on its own, once a day by default. When a new\nversion is available it can download and install it for you, then apply it the\nnext time it is safe to do so."},"596":{"id":"/updates-7","page_id":"/updates","tags":[],"type":"text","url":"/updates#automatic-updates","content":"You can tune this in the **Colophon** under **The Apparatus** (open the Index\nwith ⌘K → **Colophon**, then go to the Apparatus section):"},"597":{"id":"/updates-8","page_id":"/updates","tags":[],"type":"text","url":"/updates#automatic-updates","content":"**Automatically check for updates** — on by default. Hindsight checks daily."},"598":{"id":"/updates-9","page_id":"/updates","tags":[],"type":"text","url":"/updates#automatic-updates","content":"**Automatically download updates** — when on, a found update is fetched in the\nbackground so it is ready to install. This is available only while automatic\nchecks are on."},"599":{"id":"/updates-10","page_id":"/updates","tags":[],"type":"text","url":"/updates#automatic-updates","content":"Turn either off if you would rather decide when to update."},"600":{"id":"/updates-11","page_id":"/updates","tags":[],"type":"text","url":"/updates#checking-manually","content":"You can look for a new version at any time:"},"601":{"id":"/updates-12","page_id":"/updates","tags":[],"type":"text","url":"/updates#checking-manually","content":"**Hindsight → Check for Updates…** in the menu bar, or"},"602":{"id":"/updates-13","page_id":"/updates","tags":[],"type":"text","url":"/updates#checking-manually","content":"**Colophon → The Apparatus → Check for Updates…**"},"603":{"id":"/updates-14","page_id":"/updates","tags":[],"type":"text","url":"/updates#checking-manually","content":"If a newer version exists, Hindsight shows you what changed and offers to install\nit. If you are already current, it tells you so."},"604":{"id":"/updates-15","page_id":"/updates","tags":[],"type":"text","url":"/updates#updates-and-your-meetings","content":"Hindsight never interrupts a recording to update. Update checks are paused while\na meeting is recording, and an already-downloaded update will not relaunch the\napp mid-recording. Stop the recording and the update can proceed — a manual check\nwill remind you if a recording is in progress."},"605":{"id":"/updates-16","page_id":"/updates","tags":[],"type":"text","url":"/updates#support-and-feedback","content":"Found a bug, or have an idea? Everything lives in one place:"},"606":{"id":"/updates-17","page_id":"/updates","tags":[],"type":"text","url":"/updates#support-and-feedback","content":"**Help → Hindsight Help** or **Help → View on GitHub** opens the project on\nGitHub: github.com/iannellomarco/hindsight-next."},"607":{"id":"/updates-18","page_id":"/updates","tags":[],"type":"text","url":"/updates#support-and-feedback","content":"Open an issue there to report a problem or request a feature. When filing a bug,\nit helps to include the version you are on — you can find it in the **Colophon**\nunder **The Edition**, or in **Hindsight → About Hindsight**."}},"count":607},"sorting":{"language":"english","sortableProperties":["content","page_id","type","url"],"sortablePropertiesWithTypes":{"content":"string","page_id":"string","type":"string","url":"string"},"sorts":{"content":{"docs":{"1":295,"2":398,"3":313,"4":306,"5":397,"6":589,"7":503,"8":300,"9":333,"10":360,"11":546,"12":426,"13":486,"14":305,"15":294,"16":402,"17":487,"18":114,"19":112,"20":154,"21":580,"22":564,"23":23,"24":0,"25":5,"26":1,"27":325,"28":418,"29":182,"30":181,"31":16,"32":358,"33":380,"34":384,"35":320,"36":449,"37":448,"38":504,"39":297,"40":266,"41":296,"42":311,"43":372,"44":406,"45":556,"46":411,"47":482,"48":399,"49":383,"50":393,"51":334,"52":370,"53":330,"54":291,"55":592,"56":597,"57":54,"58":324,"59":568,"60":557,"61":396,"62":192,"63":194,"64":193,"65":197,"66":190,"67":196,"68":292,"69":403,"70":528,"71":388,"72":526,"73":479,"74":494,"75":376,"76":434,"77":195,"78":188,"79":189,"80":288,"81":191,"82":436,"83":419,"84":500,"85":198,"86":199,"87":200,"88":316,"89":456,"90":491,"91":572,"92":501,"93":511,"94":437,"95":395,"96":552,"97":505,"98":562,"99":587,"100":508,"101":429,"102":591,"103":234,"104":254,"105":233,"106":551,"107":144,"108":115,"109":42,"110":27,"111":270,"112":525,"113":260,"114":267,"115":443,"116":359,"117":119,"118":130,"119":286,"120":481,"121":420,"122":117,"123":43,"124":91,"125":593,"126":577,"127":555,"128":447,"129":569,"130":332,"131":143,"132":81,"133":298,"134":335,"135":404,"136":338,"137":337,"138":585,"139":280,"140":341,"141":600,"142":53,"143":322,"144":573,"145":45,"146":121,"147":85,"148":63,"149":175,"150":68,"151":424,"152":50,"153":66,"154":67,"155":285,"156":289,"157":113,"158":65,"159":262,"160":340,"161":339,"162":352,"163":390,"164":469,"165":389,"166":344,"167":226,"168":227,"169":228,"170":229,"171":230,"172":231,"173":354,"174":89,"175":20,"176":240,"177":321,"178":430,"